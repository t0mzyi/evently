<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= venue.name %> — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: "#1C2A3A",
              highlight: "#2C3E50",
              accent: "#ED8842",
              surface: "#F9F7F5",
            },
          },
          fontFamily: {
            heading: ["Fraunces", "serif"],
            sans: ["Inter", "sans-serif"],
          },
          keyframes: {
            'fade-in': {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          },
          animation: {
            'fade-in': 'fade-in 0.3s ease-out'
          }
        },
      },
    };
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen font-sans selection:bg-[#ED8842] selection:text-white">
  <%- include('../../partials/navbar') %>

  <div class="relative h-[45vh] md:h-[50vh] overflow-hidden">
    <img src="<%= venue.image_url[0] %>" class="absolute inset-0 w-full h-full object-cover" alt="<%= venue.name %>" />
    <div class="absolute inset-0 bg-gradient-to-t from-[#1C2A3A] via-[#1C2A3A]/40 to-transparent"></div>

    <div class="absolute bottom-0 w-full pb-10 px-6">
      <div class="max-w-7xl mx-auto">
        <span class="px-3 py-1 bg-[#ED8842] text-white text-[10px] font-bold uppercase tracking-widest rounded-full mb-4 inline-block">
          <%= venue.type %> Venue
        </span>
        <h1 class="text-4xl md:text-6xl font-heading text-white leading-tight">
          <%= venue.name %>
        </h1>
      </div>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8 space-y-16">
        <section>
          <h2 class="text-2xl font-heading mb-6">About the Space</h2>
          <p class="text-lg text-[#1C2A3A]/70 leading-relaxed font-light whitespace-pre-line">
            <%= venue.description %>
          </p>
        </section>

        <section class="grid grid-cols-2 gap-4">
          <div class="bg-white/40 p-6 rounded-3xl border border-white/60">
            <p class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest mb-1">
              Max Capacity
            </p>
            <p class="text-2xl font-heading">
              <%= venue.capacity.toLocaleString() %> Guests
            </p>
          </div>
          <div class="bg-white/40 p-6 rounded-3xl border border-white/60">
            <p class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest mb-1">
              Environment
            </p>
            <p class="text-2xl font-heading"><%= venue.type %></p>
          </div>
        </section>

        <section>
          <h2 class="text-xs font-bold mb-8 uppercase tracking-[0.2em] text-[#1C2A3A]/40">
            Venue Amenities
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% venue.amenities.forEach(item => { %>
            <div class="flex items-center gap-4 bg-white/30 p-4 rounded-2xl border border-white/40">
              <div class="w-2 h-2 rounded-full bg-[#ED8842]"></div>
              <p class="text-sm">
                <span class="font-bold text-[#1C2A3A] uppercase text-[10px] tracking-wide"><%= item.key %>:</span>
                <span class="text-[#1C2A3A]/70"><%= item.value %></span>
              </p>
            </div>
            <% }) %>
          </div>
        </section>

        <section>
          <h2 class="text-xs font-bold mb-8 uppercase tracking-[0.2em] text-[#1C2A3A]/40">
            Gallery Portfolio
          </h2>
          <div class="columns-2 md:columns-3 gap-4 space-y-4">
            <% venue.image_url.forEach((url, i) => { %>
            <img src="<%= url %>" class="w-full rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-500" alt="Venue view" />
            <% }) %>
          </div>
        </section>

        <!-- Reviews Section -->
        <section>
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-xs font-bold uppercase tracking-[0.2em] text-[#1C2A3A]/40">
              Guest Reviews
            </h2>
            <% if (currentUserId) { %>
            <button onclick="openAddReviewModal()" class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest hover:underline">
              + Add Review
            </button>
            <% } else { %>
            <a href="/login?redirect=<%= encodeURIComponent('/venue/' + venue._id) %>" class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest hover:underline">
              Login to Review
            </a>
            <% } %>
          </div>

          <div id="reviewsList" class="space-y-6">
            <% if (reviews && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
            <div class="review-card bg-white/40 p-6 rounded-3xl border border-white/60 animate-fade-in" data-review-id="<%= review._id %>">
              <div class="flex items-center gap-3 mb-3">
                <!-- Avatar: Image or Simple Icon Fallback -->
                <% if (review.avatarUrl) { %>
                <img src="<%= review.avatarUrl %>" alt="<%= review.userName %>" class="w-10 h-10 rounded-full object-cover border-2 border-white/60 avatar-img" onerror="this.onerror=null; this.parentElement.querySelector('.avatar-fallback').style.display='flex'; this.style.display='none';" />
                <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center avatar-fallback" style="display:none;">
                  <svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                  </svg>
                </div>
                <% } else { %>
                <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center">
                  <svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                  </svg>
                </div>
                <% } %>

                <div>
                  <p class="font-bold text-sm"><%= review.userName %></p>
                  <p class="text-[10px] text-[#1C2A3A]/50"><%= review.date %></p>
                </div>
                <div class="ml-auto flex items-center gap-3">
                  <div class="flex text-[#ED8842] text-sm">
                    <%= '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating) %>
                  </div>
                  <% if (review.isOwner) { %>
                  <button onclick="deleteReview('<%= review._id %>', this)" class="text-[10px] font-bold text-red-500 hover:text-red-700 uppercase tracking-widest transition-colors" aria-label="Delete review">
                    ✕
                  </button>
                  <% } %>
                </div>
              </div>
              <p class="text-[#1C2A3A]/70 text-sm leading-relaxed"><%= review.comment %></p>
            </div>
            <% }) %>
            <% } else { %>
            <p class="text-[#1C2A3A]/50 text-sm italic">No reviews yet. Be the first to share your experience!</p>
            <% } %>
          </div>
        </section>
      </div>

      <div class="lg:col-span-4 space-y-8">
        <div class="sticky top-32 space-y-6">
          <div class="bg-white/80 p-4 rounded-[2.5rem] shadow-sm border border-white/40">
            <h3 class="text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-4 px-2">
              Location
            </h3>

            <div class="w-full h-64 rounded-[1.5rem] overflow-hidden grayscale contrast-125 opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-700">
              <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?q=<%= encodeURIComponent(venue.address) %>&t=&z=13&ie=UTF8&iwloc=&output=embed">
              </iframe>
            </div>

            <div class="mt-4 px-2">
              <p class="text-sm font-medium text-[#1C2A3A] mb-2">
                <%= venue.address %>
              </p>
              <a href="<%= venue.map_url %>" target="_blank" class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest hover:underline flex items-center gap-2">
                Get Directions
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </a>
            </div>
          </div>

          <button onclick="openAvailabilityModal()" class="w-full py-6 bg-[#1C2A3A] text-white rounded-[2rem] font-bold uppercase tracking-[0.2em] text-[10px] shadow-2xl hover:bg-[#ED8842] transition-all transform hover:-translate-y-1">
            Check Availability
          </button>
        </div>
      </div>
    </div>
  </main>

  <!-- Availability Modal -->
  <div id="availabilityModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#1C2A3A]/90 backdrop-blur-sm" onclick="closeAvailabilityModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-[#F9F7F5] rounded-[3rem] p-10 shadow-2xl">
      <h3 class="text-3xl font-heading mb-8">Select Date</h3>
      <input type="date" id="checkDate" class="w-full px-6 py-4 bg-white rounded-2xl border-none outline-none mb-6 font-bold text-sm" />
      <div id="availabilityResult" class="hidden p-4 rounded-2xl text-center text-[10px] font-bold uppercase tracking-widest mb-6"></div>
      <button onclick="checkDateAvailability()" class="w-full py-5 bg-[#ED8842] text-white rounded-2xl font-bold uppercase tracking-widest text-[10px] shadow-lg">
        Verify & Proceed
      </button>
    </div>
  </div>

  <!-- Add Review Modal -->
  <div id="addReviewModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#1C2A3A]/90 backdrop-blur-sm" onclick="closeAddReviewModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-[#F9F7F5] rounded-[3rem] p-10 shadow-2xl">
      <h3 class="text-3xl font-heading mb-6">Add a Review</h3>

      <div class="mb-6">
        <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-3">
          Your Rating
        </label>
        <div class="flex gap-2" id="starRating">
          <% for (let i = 1; i <= 5; i++) { %>
          <button type="button" data-rating="<%= i %>" class="star-btn text-3xl text-[#1C2A3A]/30 hover:text-[#ED8842] transition-colors select-none">★</button>
          <% } %>
        </div>
        <input type="hidden" id="reviewRating" value="0" />
      </div>

      <div class="mb-6">
        <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-3">
          Your Review
        </label>
        <textarea id="reviewText" rows="4" class="w-full px-4 py-3 bg-white rounded-2xl border-none outline-none text-sm resize-none font-sans" placeholder="Share your experience..."></textarea>
      </div>

      <div id="reviewError" class="hidden p-3 rounded-xl bg-red-100 text-red-700 text-[10px] font-bold uppercase tracking-widest mb-4 text-center"></div>

      <div class="flex gap-3">
        <button onclick="closeAddReviewModal()" class="flex-1 py-4 bg-white/60 text-[#1C2A3A] rounded-2xl font-bold uppercase tracking-widest text-[10px] hover:bg-white/80 transition-colors">
          Cancel
        </button>
        <button onclick="submitReview(event)" class="flex-1 py-4 bg-[#ED8842] text-white rounded-2xl font-bold uppercase tracking-widest text-[10px] shadow-lg hover:bg-[#1C2A3A] transition-colors">
          Submit
        </button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteConfirmModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#1C2A3A]/90 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-sm bg-[#F9F7F5] rounded-[3rem] p-8 shadow-2xl text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      </div>
      <h3 class="text-2xl font-heading mb-2">Delete Review?</h3>
      <p class="text-[#1C2A3A]/70 text-sm mb-6">This action cannot be undone.</p>

      <div class="flex gap-3">
        <button onclick="closeDeleteModal()" class="flex-1 py-4 bg-white/60 text-[#1C2A3A] rounded-2xl font-bold uppercase tracking-widest text-[10px] hover:bg-white/80 transition-colors">
          Cancel
        </button>
        <button onclick="confirmDelete()" class="flex-1 py-4 bg-red-500 text-white rounded-2xl font-bold uppercase tracking-widest text-[10px] shadow-lg hover:bg-red-600 transition-colors">
          Delete
        </button>
      </div>
    </div>
  </div>

  <!-- ✅ Custom Toast Notification (Your Exact Design) -->
  <div id="toast" class="fixed left-1/2 -translate-x-1/2 transition-all duration-500 ease-in-out" style="top: -100px; z-index: 9999;">
    <div id="toastContent" class="bg-[#1C2A3A] text-white px-6 py-3 rounded-2xl shadow-2xl border border-white/20 flex items-center gap-3">
      <div id="toastIcon"></div>
      <span id="toastMessage" class="text-sm font-bold tracking-wide"></span>
    </div>
  </div>

  <script>
    // ===== EXISTING AVAILABILITY LOGIC =====
    window.onload = () => {
      const today = new Date().toISOString().split("T")[0];
      document.getElementById("checkDate").setAttribute("min", today);

      // Check URL params for toast notification on page load
      checkUrlParamsForToast();
    };

    function openAvailabilityModal() {
      document.getElementById("availabilityModal").classList.remove("hidden");
    }

    function closeAvailabilityModal() {
      document.getElementById("availabilityModal").classList.add("hidden");
    }

    function checkDateAvailability() {
      const date = document.getElementById("checkDate").value;
      const resultDiv = document.getElementById("availabilityResult");
      if (!date) return;

      const venueName = "<%= encodeURIComponent(venue.name) %>";
      const venueId = "<%= venue._id %>";

      const isAvailable = Math.random() > 0.2;
      if (isAvailable) {
        resultDiv.textContent = "Date Available";
        resultDiv.className =
          "p-4 rounded-2xl text-center text-[10px] font-bold bg-green-100 text-green-700 block mb-6";
        setTimeout(() => {
          window.location.href = `/createEvent?venue=${venueName}&id=${venueId}&date=${date}`;
        }, 1000);
      } else {
        resultDiv.textContent = "Date Reserved";
        resultDiv.className =
          "p-4 rounded-2xl text-center text-[10px] font-bold bg-red-100 text-red-700 block mb-6";
      }
    }

    // ===== CUSTOM TOAST NOTIFICATION (Your Exact Code) =====
    const urlParams = new URLSearchParams(window.location.search);

    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const msgEl = document.getElementById('toastMessage');
      const iconEl = document.getElementById('toastIcon');

      if (!toast || !msgEl || !iconEl) return;

      msgEl.textContent = message;
      iconEl.className = type === 'success' ? 'bg-green-500 rounded-full p-1' : 'bg-red-500 rounded-full p-1';

      iconEl.innerHTML = type === 'success' ?
        '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>' :
        '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';

      // Slide down
      setTimeout(() => {
        toast.style.top = '100px';
      }, 100);

      // Slide up and clean URL
      setTimeout(() => {
        toast.style.top = '-100px';
        const newUrl = window.location.pathname;
        window.history.replaceState({}, document.title, newUrl);
      }, 3500);
    }

    // Check URL params on page load
    function checkUrlParamsForToast() {
      if (urlParams.has('status')) {
        const status = urlParams.get('status');
        const message = urlParams.get('message');

        if (status === 'error') {
          showToast(message || 'An error occurred', 'error');
        } else {
          showToast(message || 'Success!');
        }
      }
    }

    // ===== REVIEW SYSTEM =====
    let selectedRating = 0;
    let reviewToDelete = null;

    // ✅ Helper: Build avatar HTML (image or simple icon fallback)
    function getAvatarHTML(avatarUrl, userName) {
      const userIcon = `<svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>`;

      if (avatarUrl) {
        return `
          <img 
            src="${avatarUrl}" 
            alt="${userName}"
            class="w-10 h-10 rounded-full object-cover border-2 border-white/60 avatar-img"
            onerror="this.onerror=null; this.parentElement.querySelector('.avatar-fallback').style.display='flex'; this.style.display='none';"
          />
          <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center avatar-fallback" style="display:none;">
            ${userIcon}
          </div>
        `;
      } else {
        return `
          <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center">
            ${userIcon}
          </div>
        `;
      }
    }

    // Star rating interaction
    document.querySelectorAll('.star-btn').forEach(star => {
      star.addEventListener('click', function() {
        selectedRating = parseInt(this.dataset.rating);
        document.getElementById('reviewRating').value = selectedRating;
        updateStars(selectedRating);
      });

      star.addEventListener('mouseenter', function() {
        const hoverRating = parseInt(this.dataset.rating);
        updateStars(hoverRating, true);
      });
    });

    document.getElementById('starRating').addEventListener('mouseleave', function() {
      updateStars(selectedRating);
    });

    function updateStars(rating, isHover = false) {
      document.querySelectorAll('.star-btn').forEach((star, index) => {
        if (index < rating) {
          star.classList.remove('text-[#1C2A3A]/30');
          star.classList.add('text-[#ED8842]');
        } else {
          star.classList.remove('text-[#ED8842]');
          star.classList.add('text-[#1C2A3A]/30');
        }
      });
    }

    function openAddReviewModal() {
      selectedRating = 0;
      document.getElementById('reviewRating').value = '0';
      document.getElementById('reviewText').value = '';
      document.getElementById('reviewError').classList.add('hidden');
      updateStars(0);
      document.getElementById('addReviewModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeAddReviewModal() {
      document.getElementById('addReviewModal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    async function submitReview(event) {
      const rating = document.getElementById('reviewRating').value;
      const text = document.getElementById('reviewText').value.trim();
      const errorDiv = document.getElementById('reviewError');

      if (!rating || rating === '0') {
        showError('Please select a rating');
        return;
      }
      if (text.length < 10) {
        showError('Review must be at least 10 characters');
        return;
      }

      errorDiv.classList.add('hidden');

      // Show loading state on button
      const submitBtn = event.target;
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      try {
        const response = await fetch('/venue/review', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            venueId: '<%= venue._id %>',
            rating: parseInt(rating),
            comment: text,
          })
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          console.error('Review error ', errorData);
          throw new Error(errorData.message || 'Failed to submit review');
        }

        const result = await response.json();

        // ✅ FIX: Use userName from API response (not EJS injection)
        if (result.review && result.success) {
          addReviewToDOM({
            _id: result.review._id,
            rating: result.review.rating,
            comment: result.review.comment,
            userName: result.review.userName, // ← Backend sends "firstName lastName"
            avatarUrl: result.review.avatarUrl,
            date: result.review.date, // ← Backend sends formatted date
            isOwner: true
          });

          showToast('Your review has been submitted successfully!', 'success');
        }

        // Reset form and close
        document.getElementById('reviewText').value = '';
        document.getElementById('reviewRating').value = '0';
        updateStars(0);
        selectedRating = 0;
        closeAddReviewModal();

      } catch (error) {
        console.error('Review error:', error);
        showToast(error.message || 'Something went wrong. Please try again.', 'error');
        showError(error.message || 'Something went wrong. Please try again.');
      } finally {
        const submitBtn = document.querySelector('#addReviewModal button[type="button"]:last-child');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit';
        }
      }
    }

    function showError(message) {
      const errorDiv = document.getElementById('reviewError');
      errorDiv.textContent = message;
      errorDiv.classList.remove('hidden');
    }

    // ===== DELETE REVIEW SYSTEM =====

    function deleteReview(reviewId, buttonEl) {
      reviewToDelete = {
        id: reviewId,
        buttonEl
      };
      document.getElementById('deleteConfirmModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeDeleteModal() {
      document.getElementById('deleteConfirmModal').classList.add('hidden');
      document.body.style.overflow = '';
      reviewToDelete = null;
    }

    async function confirmDelete() {
      if (!reviewToDelete) return;

      const {
        id,
        buttonEl
      } = reviewToDelete;
      const reviewCard = buttonEl.closest('.review-card');

      try {
        // For dummy reviews: just remove from DOM without API call
        if (id.startsWith('dummy-')) {
          animateRemove(reviewCard);
          showToast('Review deleted successfully!', 'success');
          closeDeleteModal();
          return;
        }

        // Real review: call DELETE API, then remove from DOM on success
        const response = await fetch(`/venue/review`, {
          method: 'DELETE',
          body: JSON.stringify({
            id
          }),
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.message || 'Failed to delete review');
        }

        // Remove from DOM with animation after successful API call
        animateRemove(reviewCard);
        showToast('Review deleted successfully!', 'success');
        closeDeleteModal();

      } catch (error) {
        console.error('Delete error:', error);
        showToast(error.message || 'Failed to delete review. Please try again.', 'error');
        closeDeleteModal();
      }
    }

    // ✅ Helper: Animate and remove review card from DOM (no reload)
    function animateRemove(element) {
      element.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      element.style.opacity = '0';
      element.style.transform = 'translateX(-20px)';
      setTimeout(() => {
        element.remove();
        // Show empty state if no reviews left
        const reviewsList = document.getElementById('reviewsList');
        if (reviewsList.querySelectorAll('.review-card').length === 0) {
          reviewsList.innerHTML = '<p class="text-[#1C2A3A]/50 text-sm italic">No reviews yet. Be the first to share your experience!</p>';
        }
      }, 300);
    }

    // ✅ FIX: Add review to DOM using API response data (no "Guest User")
    function addReviewToDOM(review) {
      const reviewsList = document.getElementById('reviewsList');

      // Remove empty state placeholder if it exists
      const emptyState = reviewsList.querySelector('p.italic');
      if (emptyState) emptyState.remove();

      const stars = '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating);
      const avatarHTML = getAvatarHTML(review.avatarUrl, review.userName);

      const reviewHTML = `
        <div class="review-card bg-white/40 p-6 rounded-3xl border border-white/60 animate-fade-in" data-review-id="${review._id}">
          <div class="flex items-center gap-3 mb-3">
            ${avatarHTML}
            <div>
              <p class="font-bold text-sm">${review.userName}</p>
              <p class="text-[10px] text-[#1C2A3A]/50">${review.date}</p>
            </div>
            <div class="ml-auto flex items-center gap-3">
              <div class="flex text-[#ED8842] text-sm">${stars}</div>
              <button onclick="deleteReview('${review._id}', this)" class="text-[10px] font-bold text-red-500 hover:text-red-700 uppercase tracking-widest transition-colors" aria-label="Delete review">
                ✕
              </button>
            </div>
          </div>
          <p class="text-[#1C2A3A]/70 text-sm leading-relaxed">
            ${review.comment}
          </p>
        </div>
      `;
      reviewsList.insertAdjacentHTML('afterbegin', reviewHTML);
    }

    // Close modals on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeAddReviewModal();
        closeAvailabilityModal();
        closeDeleteModal();
      }
    });
  </script>
</body>

</html>