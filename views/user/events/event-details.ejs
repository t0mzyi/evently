  <script src="/assets/js/app.js"></script>

  <!-- Enhanced Magnifying Glass JavaScript -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const magnifyContainers = document.querySelectorAll('.magnify-container');
      magnifyContainers.forEach(container => {
        const magnifier = container.querySelector('.magnifier');
        const zoomedImage = container.querySelector('.zoomed-image');
        const img = container.querySelector('.magnify-image');
        const imgSrc = container.dataset.magnify || img.src;
        zoomedImage.style.backgroundImage = `url('${imgSrc}')`;

        container.addEventListener('mousemove', (e) => {
          const rect = container.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          magnifier.style.left = `${x}px`;
          magnifier.style.top = `${y}px`;
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          zoomedImage.style.backgroundPosition = `${percentX}% ${percentY}%`;
        });

        container.addEventListener('touchmove', (e) => {
          e.preventDefault();
          const rect = container.getBoundingClientRect();
          const touch = e.touches[0];
          const x = touch.clientX - rect.left;
          const y = touch.clientY - rect.top;
          magnifier.style.left = `${x}px`;
          magnifier.style.top = `${y}px`;
          const percentX = (x / rect.width) * 100;
          const percentY = (y / rect.height) * 100;
          zoomedImage.style.backgroundPosition = `${percentX}% ${percentY}%`;
          magnifier.style.display = 'block';
          zoomedImage.style.opacity = '1';
        });

        container.addEventListener('touchend', () => {
          magnifier.style.display = 'none';
          zoomedImage.style.opacity = '0';
        });
      });

      // ✅ Bookmark Toggle Functionality (Same as events page)
      const bookmarkBtn = document.getElementById('heroBookmarkBtn');
      if (bookmarkBtn) {
        bookmarkBtn.addEventListener('click', async function(e) {
          e.stopPropagation();
          e.preventDefault();

          const eventId = this.dataset.eventId;
          const icon = this.querySelector('svg');
          const isCurrentlyBookmarked = icon.getAttribute('fill') === 'currentColor';

          // Optimistic UI update
          if (isCurrentlyBookmarked) {
            icon.outerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-gray-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>`;
          } else {
            icon.outerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-red-500">
                <path d="m11.645 20.91.007-.003.022-.012a15.247 15.247 0 0 1 .383-.218 25.18 25.18 0 0 1 4.244-3.17C18.313 15.36 20.25 12.174 20.25 8.25 20.25 5.322 17.784 3 14.85 3A5.5 5.5 0 0 0 9.313 3c-2.935 0-5.4 2.322-5.4 5.25 0 3.925 1.937 7.111 4.739 9.256a25.175 25.175 0 0 1 4.244 3.17 15.247 15.247 0 0 1 .383.219l.022.012.007.004.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
              </svg>`;
          }

          try {
            const response = await fetch(`/toggleBookmark/${eventId}`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              credentials: 'include'
            });

            if (!response.ok) throw new Error('Failed to toggle bookmark');

            // Show success toast if you have toast functionality
            if (typeof showToast === 'function') {
              showToast(isCurrentlyBookmarked ? 'Removed from bookmarks' : 'Added to bookmarks', 'success');
            }
          } catch (error) {
            console.error('Error toggling bookmark:', error);
            // Revert UI on error
            if (isCurrentlyBookmarked) {
              icon.outerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-red-500">
                  <path d="m11.645 20.91.007-.003.022-.012a15.247 15.247 0 0 1 .383-.218 25.18 25.18 0 0 1 4.244-3.17C18.313 15.36 20.25 12.174 20.25 8.25 20.25 5.322 17.784 3 14.85 3A5.5 5.5 0 0 0 9.313 3c-2.935 0-5.4 2.322-5.4 5.25 0 3.925 1.937 7.111 4.739 9.256a25.175 25.175 0 0 1 4.244 3.17 15.247 15.247 0 0 1 .383.219l.022.012.007.004.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
                </svg>`;
            } else {
              icon.outerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-gray-400">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
                </svg>`;
            }

            if (typeof showToast === 'function') {
              showToast('Failed to update bookmark', 'error');
            }
          }
        });
      }
    });
  </script>

  <!-- ✅ Toast HTML -->
  <div id="toast" class="fixed left-1/2 -translate-x-1/2 transition-all duration-500 ease-in-out" style="top: -100px; z-index: 9999;">
    <div id="toastContent" class="bg-[#1C2A3A] text-white px-6 py-3 rounded-2xl shadow-2xl border border-white/20 flex items-center gap-3">
      <div id="toastIcon"></div>
      <span id="toastMessage" class="text-sm font-bold tracking-wide"></span>
    </div>
  </div>

  <!-- ✅ Add Review Modal -->
  <div id="addReviewModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#1C2A3A]/90 backdrop-blur-sm" onclick="closeAddReviewModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-[#F9F7F5] rounded-[3rem] p-10 shadow-2xl">
      <h3 class="text-3xl font-heading mb-6">Add a Review</h3>
      <div class="mb-6">
        <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-3">Your Rating</label>
        <div class="flex gap-2" id="starRating">
          <% for (let i = 1; i <= 5; i++) { %>
          <button type="button" data-rating="<%= i %>" class="star-btn text-3xl text-[#1C2A3A]/30 hover:text-[#ED8842] transition-colors select-none">★</button>
          <% } %>
        </div>
        <input type="hidden" id="reviewRating" value="0" />
      </div>
      <div class="mb-6">
        <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-3">Your Review</label>
        <textarea id="reviewText" rows="4" class="w-full px-4 py-3 bg-white rounded-2xl border-none outline-none text-sm resize-none font-sans" placeholder="Share your experience..."></textarea>
      </div>
      <div id="reviewError" class="hidden p-3 rounded-xl bg-red-100 text-red-700 text-[10px] font-bold uppercase tracking-widest mb-4 text-center"></div>
      <div class="flex gap-3">
        <button onclick="closeAddReviewModal()" class="flex-1 py-4 bg-white/60 text-[#1C2A3A] rounded-2xl font-bold uppercase tracking-widest text-[10px] hover:bg-white/80 transition-colors">Cancel</button>
        <button onclick="submitReview(event)" class="flex-1 py-4 bg-[#ED8842] text-white rounded-2xl font-bold uppercase tracking-widest text-[10px] shadow-lg hover:bg-[#1C2A3A] transition-colors">Submit</button>
      </div>
    </div>
  </div>

  <!-- ✅ Delete Confirmation Modal -->
  <div id="deleteConfirmModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-[#1C2A3A]/90 backdrop-blur-sm" onclick="closeDeleteModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-sm bg-[#F9F7F5] rounded-[3rem] p-8 shadow-2xl text-center">
      <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-100 flex items-center justify-center">
        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
      </div>
      <h3 class="text-2xl font-heading mb-2">Delete Review?</h3>
      <p class="text-[#1C2A3A]/70 text-sm mb-6">This action cannot be undone.</p>
      <div class="flex gap-3">
        <button onclick="closeDeleteModal()" class="flex-1 py-4 bg-white/60 text-[#1C2A3A] rounded-2xl font-bold uppercase tracking-widest text-[10px] hover:bg-white/80 transition-colors">Cancel</button>
        <button onclick="confirmDelete()" class="flex-1 py-4 bg-red-500 text-white rounded-2xl font-bold uppercase tracking-widest text-[10px] shadow-lg hover:bg-red-600 transition-colors">Delete</button>
      </div>
    </div>
  </div>

  <!-- ✅ Review System JavaScript -->
  <script>
    // ===== REVIEW SYSTEM =====
    let selectedRating = 0;
    let reviewToDelete = null;

    // ✅ Helper: Build avatar HTML
    function getAvatarHTML(avatarUrl, userName) {
      const userIcon = `<svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>`;

      if (avatarUrl) {
        return `
          <img src="${avatarUrl}" alt="${userName}" class="w-10 h-10 rounded-full object-cover border-2 border-white/60 avatar-img" onerror="this.onerror=null; this.parentElement.querySelector('.avatar-fallback').style.display='flex'; this.style.display='none';" />
          <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center avatar-fallback" style="display:none;">${userIcon}</div>
        `;
      } else {
        return `<div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center">${userIcon}</div>`;
      }
    }

    // ✅ Custom Toast Notification
    const urlParams = new URLSearchParams(window.location.search);

    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const msgEl = document.getElementById('toastMessage');
      const iconEl = document.getElementById('toastIcon');
      if (!toast || !msgEl || !iconEl) return;

      msgEl.textContent = message;
      iconEl.className = type === 'success' ? 'bg-green-500 rounded-full p-1' : 'bg-red-500 rounded-full p-1';
      iconEl.innerHTML = type === 'success' ?
        '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>' :
        '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>';

      setTimeout(() => {
        toast.style.top = '100px';
      }, 100);
      setTimeout(() => {
        toast.style.top = '-100px';
        const newUrl = window.location.pathname;
        window.history.replaceState({}, document.title, newUrl);
      }, 3500);
    }

    function checkUrlParamsForToast() {
      if (urlParams.has('status')) {
        const status = urlParams.get('status');
        const message = urlParams.get('message');
        if (status === 'error') {
          showToast(message || 'An error occurred', 'error');
        } else {
          showToast(message || 'Success!');
        }
      }
    }

    // ✅ FIXED: Update stars with proper logic
    function updateStars(rating, isHover = false) {
      const stars = document.querySelectorAll('.star-btn');
      stars.forEach((star, index) => {
        star.classList.remove('text-[#ED8842]', 'text-[#1C2A3A]/30');
        if (isHover ? (index < rating) : (index < selectedRating)) {
          star.classList.add('text-[#ED8842]');
        } else {
          star.classList.add('text-[#1C2A3A]/30');
        }
      });
    }

    // ✅ FIXED: Initialize star listeners AFTER modal is shown
    function initStarListeners() {
      const stars = document.querySelectorAll('.star-btn');
      const starContainer = document.getElementById('starRating');

      stars.forEach(star => {
        star.addEventListener('click', function(e) {
          e.stopPropagation();
          selectedRating = parseInt(this.dataset.rating);
          document.getElementById('reviewRating').value = selectedRating;
          updateStars(selectedRating);
        });

        star.addEventListener('mouseenter', function() {
          const hoverRating = parseInt(this.dataset.rating);
          updateStars(hoverRating, true);
        });
      });

      starContainer.addEventListener('mouseleave', function() {
        updateStars(selectedRating);
      });
    }

    // ✅ FIXED: Open modal and init stars
    function openAddReviewModal() {
      selectedRating = 0;
      document.getElementById('reviewRating').value = '0';
      document.getElementById('reviewText').value = '';
      document.getElementById('reviewError').classList.add('hidden');
      updateStars(0);

      document.getElementById('addReviewModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      setTimeout(initStarListeners, 50);
    }

    function closeAddReviewModal() {
      document.getElementById('addReviewModal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    // ✅ Submit Review
    async function submitReview(event) {
      const rating = document.getElementById('reviewRating').value;
      const text = document.getElementById('reviewText').value.trim();
      const errorDiv = document.getElementById('reviewError');

      if (!rating || rating === '0') {
        showError('Please select a rating');
        return;
      }
      if (text.length < 10) {
        showError('Review must be at least 10 characters');
        return;
      }

      errorDiv.classList.add('hidden');
      const submitBtn = event.target;
      const originalText = submitBtn.textContent;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      try {
        const response = await fetch('/event/reviews', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            eventId: '<%= event._id %>',
            rating: parseInt(rating),
            comment: text,
          })
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.message || 'Failed to submit review');
        }

        const result = await response.json();
        if (result.review && result.success) {
          addReviewToDOM({
            _id: result.review._id,
            rating: result.review.rating,
            comment: result.review.comment,
            userName: result.review.userName,
            avatarUrl: result.review.avatarUrl,
            date: result.review.date,
            isOwner: true
          });
          showToast('Your review has been submitted successfully!', 'success');
        }

        document.getElementById('reviewText').value = '';
        document.getElementById('reviewRating').value = '0';
        updateStars(0);
        selectedRating = 0;
        closeAddReviewModal();

      } catch (error) {
        console.error('Review error:', error);
        showToast(error.message || 'Something went wrong. Please try again.', 'error');
        showError(error.message || 'Something went wrong. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit';
      }
    }

    function showError(message) {
      const errorDiv = document.getElementById('reviewError');
      errorDiv.textContent = message;
      errorDiv.classList.remove('hidden');
    }

    // ✅ Delete Review Functions
    function deleteReview(reviewId, buttonEl) {
      reviewToDelete = {
        id: reviewId,
        buttonEl
      };
      document.getElementById('deleteConfirmModal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeDeleteModal() {
      document.getElementById('deleteConfirmModal').classList.add('hidden');
      document.body.style.overflow = '';
      reviewToDelete = null;
    }

    async function confirmDelete() {
      if (!reviewToDelete) return;
      const {
        id,
        buttonEl
      } = reviewToDelete;
      const reviewCard = buttonEl.closest('.review-card');

      try {
        if (id.startsWith('dummy-')) {
          animateRemove(reviewCard);
          showToast('Review deleted successfully!', 'success');
          closeDeleteModal();
          return;
        }

        const response = await fetch(`/event/reviews/${id}`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        if (!response.ok) {
          const errorData = await response.json().catch(() => ({}));
          throw new Error(errorData.message || 'Failed to delete review');
        }

        animateRemove(reviewCard);
        showToast('Review deleted successfully!', 'success');
        closeDeleteModal();

      } catch (error) {
        console.error('Delete error:', error);
        showToast(error.message || 'Failed to delete review. Please try again.', 'error');
        closeDeleteModal();
      }
    }

    function animateRemove(element) {
      element.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
      element.style.opacity = '0';
      element.style.transform = 'translateX(-20px)';
      setTimeout(() => {
        element.remove();
        const reviewsList = document.getElementById('reviewsList');
        if (reviewsList && reviewsList.querySelectorAll('.review-card').length === 0) {
          reviewsList.innerHTML = '<p class="text-[#1C2A3A]/50 text-sm italic">No reviews yet. Be the first to share your experience!</p>';
        }
      }, 300);
    }

    function addReviewToDOM(review) {
      const reviewsList = document.getElementById('reviewsList');
      if (!reviewsList) return;

      const emptyState = reviewsList.querySelector('p.italic');
      if (emptyState) emptyState.remove();

      const stars = '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating);
      const avatarHTML = getAvatarHTML(review.avatarUrl, review.userName);

      const reviewHTML = `
        <div class="review-card bg-white/40 p-6 rounded-3xl border border-white/60 animate-fade-in" data-review-id="${review._id}">
          <div class="flex items-center gap-3 mb-3">
            ${avatarHTML}
            <div>
              <p class="font-bold text-sm">${review.userName}</p>
              <p class="text-[10px] text-[#1C2A3A]/50">${review.date}</p>
            </div>
            <div class="ml-auto flex items-center gap-3">
              <div class="flex text-[#ED8842] text-sm">${stars}</div>
              <button onclick="deleteReview('${review._id}', this)" class="text-[10px] font-bold text-red-500 hover:text-red-700 uppercase tracking-widest transition-colors" aria-label="Delete review">✕</button>
            </div>
          </div>
          <p class="text-[#1C2A3A]/70 text-sm leading-relaxed">${review.comment}</p>
        </div>
      `;
      reviewsList.insertAdjacentHTML('afterbegin', reviewHTML);
    }

    // Close modals on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeAddReviewModal();
        closeDeleteModal();
      }
    });

    // ✅ Initialize toast check on page load
    window.addEventListener('load', checkUrlParamsForToast);
  </script>

</body>

