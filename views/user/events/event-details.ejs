<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: '#1C2A3A',
              highlight: '#2C3E50',
              secondary: '#1C2A3A',
              accent: '#5C7C8A',
              dark: '#1C2A3A',
              surface: '#F9F7F5',
            },
            apple: {
              bg: '#EAE0CF',
              card: 'rgba(255, 255, 255, 0.6)',
              text: '#1C2A3A',
              secondary: '#5C7C8A',
              accent: '#1C2A3A'
            }
          },
          animation: {
            'fade-in': 'fadeIn 0.8s ease-out forwards',
            'slide-up': 'slideUp 0.8s ease-out forwards',
          },
          keyframes: {
            fadeIn: {
              '0%': {
                opacity: '0'
              },
              '100%': {
                opacity: '1'
              },
            },
            slideUp: {
              '0%': {
                opacity: '0',
                transform: 'translateY(20px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              },
            }
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <style>
    .transition-all-300 {
      transition: all 0.3s ease-in-out;
    }

    .magnify-container {
      position: relative;
      display: inline-block;
      cursor: crosshair;
      z-index: 2;
    }

    .magnify-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .magnifier {
      position: absolute;
      border-radius: 50%;
      width: 200px;
      height: 200px;
      background: rgba(255, 255, 255, 0.15);
      box-shadow: 0 0 0 3px rgba(28, 42, 58, 0.4), 0 0 25px rgba(0, 0, 0, 0.3);
      pointer-events: none;
      transform: translate(-50%, -50%);
      z-index: 100;
      backdrop-filter: blur(3px);
      display: none;
    }

    .magnifier::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      border-radius: 50%;
      box-shadow: inset 0 0 25px rgba(0, 0, 0, 0.4);
    }

    .magnify-container:hover .magnifier {
      display: block;
    }

    .zoomed-image {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border-radius: 50%;
      background-size: 250% 250%;
      background-repeat: no-repeat;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.1s ease;
    }

    .magnify-container:hover .zoomed-image {
      opacity: 1;
    }

    .magnify-container:hover .magnify-image {
      transform: scale(1.05);
    }

    .magnify-container {
      user-select: none;
      -webkit-user-select: none;
    }

    .hero-magnify-wrapper {
      position: relative;
      z-index: 2;
    }

    .hero-gradient {
      position: absolute;
      inset: 0;
      z-index: 1;
    }

    .progress-bg {
      background-color: rgba(28, 42, 58, 0.1);
      border-radius: 9999px;
      height: 6px;
      width: 100%;
      overflow: hidden;
      margin-top: 0.5rem;
    }

    .progress-fill {
      height: 100%;
      border-radius: 9999px;
      transition: width 1s ease-out;
    }

    /* ✅ Star button transitions */
    .star-btn {
      transition: color 0.15s ease-in-out, transform 0.1s ease;
      cursor: pointer;
      user-select: none;
    }

    .star-btn:active {
      transform: scale(1.1);
    }

    /* ✅ Bookmark button styles */
    .bookmark-btn-detail {
      transition: all 0.2s ease;
      z-index: 30;
    }

    .bookmark-btn-detail:hover {
      transform: scale(1.1);
    }

    .bookmark-btn-detail:active {
      transform: scale(0.95);
    }
  </style>
</head>

<body class="bg-apple-bg text-apple-text animate-fade-in">

  <!-- Navigation -->
  <%- include('../../partials/navbar') %>

  <main class="pt-32 pb-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

      <!-- Left Column: Immersive Content -->
      <div class="lg:col-span-8 space-y-16 animate-slide-up">
        <!-- Event Hero -->
        <div class="relative h-[500px] md:h-[600px] rounded-[3rem] overflow-hidden card-shadow transition-all-300 hover:shadow-2xl">
          <div class="h-full rounded-[3rem] overflow-hidden relative">
            <div class="hero-magnify-wrapper w-full h-full">
              <div class="magnify-container w-full h-full" data-magnify="<%= event.galleryImages[0]%>">
                <img src="<%= event.galleryImages[0]%>" class="magnify-image" alt="Event Hero">
                <div class="magnifier">
                  <div class="zoomed-image" style="background-image: url('<%= event.galleryImages[0]%>')"></div>
                </div>
              </div>
              <div class="hero-gradient bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            </div>

            <!-- ✅ Bookmark Button (Added to Hero Image) -->
            <button class="bookmark-btn-detail absolute top-8 right-8 p-3 bg-white/90 backdrop-blur-md rounded-full shadow-lg z-30" data-event-id="<%= event._id %>" id="heroBookmarkBtn">
              <% const isBookmarked = userBookmarks && userBookmarks.includes(event._id.toString()); %>
              <% if (isBookmarked) { %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-red-500">
                <path d="m11.645 20.91.007-.003.022-.012a15.247 15.247 0 0 1 .383-.218 25.18 25.18 0 0 1 4.244-3.17C18.313 15.36 20.25 12.174 20.25 8.25 20.25 5.322 17.784 3 14.85 3A5.5 5.5 0 0 0 9.313 3c-2.935 0-5.4 2.322-5.4 5.25 0 3.925 1.937 7.111 4.739 9.256a25.175 25.175 0 0 1 4.244 3.17 15.247 15.247 0 0 1 .383.219l.022.012.007.004.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
              </svg>
              <% } else { %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-7 h-7 text-gray-400">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
              <% } %>
            </button>
          </div>
          <div class="absolute top-8 left-8 flex space-x-3 z-10">
            <span class="px-4 py-2 bg-white/40 backdrop-blur-md border border-white/40 rounded-full text-xs font-semibold text-theme-dark uppercase tracking-wider transition-all-300 hover:bg-white/60"><%= event.categoryId.name%></span>
          </div>
        </div>

        <!-- Description -->
        <div class="bg-white/40 backdrop-blur-md rounded-[3rem] p-10 card-shadow border border-white/60 transition-all-300 hover:bg-white/50">
          <div class="prose prose-lg max-w-none text-apple-text font-normal leading-relaxed">
            <h2 class="text-4xl font-semibold mb-8 text-theme-dark text-left">About the Event</h2>
            <p class="text-apple-secondary text-left"><%= event.description%></p>
          </div>
        </div>

        <!-- Gallery -->
        <section class="bg-theme-surface/60 backdrop-blur-md rounded-[3rem] p-10 card-shadow border border-white/10 transition-all-300 hover:bg-theme-surface/70">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-3xl font-semibold text-theme-dark text-left">Atmosphere</h2>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <% for(let i=0;i<event.galleryImages.length;i++){%>
            <div class="magnify-container w-full h-48 rounded-3xl overflow-hidden transition-all-300 hover:shadow-lg transform hover:-translate-y-1">
              <img src="<%= event.galleryImages[i] %>" class="magnify-image" alt="Gallery">
              <div class="magnifier">
                <div class="zoomed-image" style="background-image: url('<%= event.galleryImages[i]%>')"></div>
              </div>
            </div>
            <%}%>
          </div>
        </section>

        <!-- Venue & Location -->
        <section class="bg-theme-surface/80 backdrop-blur-md rounded-[3rem] p-10 card-shadow border border-white/10 transition-all-300 hover:shadow-lg">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
            <div class="space-y-6">
              <div>
                <h2 class="text-3xl font-semibold text-theme-dark text-left mb-2">Venue</h2>
                <h3 class="text-xl font-semibold text-theme-dark text-left"><%= venue.name%></h3>
          </div>
          <p class="text-apple-secondary leading-relaxed text-left"><%= venue.description%></p>
          <div class="space-y-4">
            <div class="flex items-center space-x-3 text-sm group cursor-pointer">
              <div class="p-2 bg-theme-primary/10 rounded-full text-theme-primary transition-all-300 group-hover:bg-theme-primary group-hover:text-white flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <span class="font-medium text-left"><%= venue.address%></span>
            </div>
            <a href="<%= venue.map_url%>" class="inline-flex items-center justify-center px-6 py-3 bg-theme-primary/10 text-theme-primary rounded-full text-sm font-bold hover:bg-theme-primary hover:text-white transition-all-300 w-full md:w-auto">
              Get Directions
            </a>
          </div>
      </div>
      <div class="h-64 bg-apple-bg rounded-[2.5rem] overflow-hidden card-shadow border border-black/5 transition-all-300 hover:shadow-inner">
        <div class="w-full h-full bg-[#E5E3DF] flex items-center justify-center relative">
          <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?q=<%= encodeURIComponent(venue.address) %>&z=15&output=embed" class="absolute inset-0 grayscale hover:grayscale-0 transition-all-300 duration-700"></iframe>
        </div>
      </div>
    </div>
    </section>

    <!-- ✅ Reviews Section (Only shows if event is over) -->
    <% 
          const eventDate = new Date(event.startDate);
          const today = new Date();
          today.setHours(0, 0, 0, 0);
          eventDate.setHours(0, 0, 0, 0);
          const isEventOver = eventDate < today;
        %>

    <% if (isEventOver) { %>
    <section class="bg-theme-surface/60 backdrop-blur-md rounded-[3rem] p-10 card-shadow border border-white/10 transition-all-300 hover:bg-theme-surface/70">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-3xl font-semibold text-theme-dark text-left">Event Reviews</h2>
        <% if (currentUserId) { %>
        <button onclick="openAddReviewModal()" class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest hover:underline">
          + Add Review
        </button>
        <% } else { %>
        <a href="/login?redirect=<%= encodeURIComponent('/event/' + event._id) %>" class="text-[10px] font-bold text-[#ED8842] uppercase tracking-widest hover:underline">
          Login to Review
        </a>
        <% } %>
      </div>

      <div id="reviewsList" class="space-y-6">
        <% if (reviews && reviews.length > 0) { %>
        <% reviews.forEach(review => { %>
        <div class="review-card bg-white/40 p-6 rounded-3xl border border-white/60 animate-fade-in" data-review-id="<%= review._id %>">
          <div class="flex items-center gap-3 mb-3">
            <!-- Avatar: Image or Simple Icon Fallback -->
            <% if (review.avatarUrl) { %>
            <img src="<%= review.avatarUrl %>" alt="<%= review.userName %>" class="w-10 h-10 rounded-full object-cover border-2 border-white/60 avatar-img" onerror="this.onerror=null; this.parentElement.querySelector('.avatar-fallback').style.display='flex'; this.style.display='none';" />
            <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center avatar-fallback" style="display:none;">
              <svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
              </svg>
            </div>
            <% } else { %>
            <div class="w-10 h-10 rounded-full bg-[#ED8842] flex items-center justify-center">
              <svg class="w-5 h-5 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
              </svg>
            </div>
            <% } %>

            <div>
              <p class="font-bold text-sm"><%= review.userName %></p>
              <p class="text-[10px] text-[#1C2A3A]/50"><%= review.date %></p>
            </div>
            <div class="ml-auto flex items-center gap-3">
              <div class="flex text-[#ED8842] text-sm">
                <%= '★'.repeat(review.rating) + '☆'.repeat(5 - review.rating) %>
              </div>
              <% if (review.isOwner) { %>
              <button onclick="deleteReview('<%= review._id %>', this)" class="text-[10px] font-bold text-red-500 hover:text-red-700 uppercase tracking-widest transition-colors" aria-label="Delete review">
                ✕
              </button>
              <% } %>
            </div>
          </div>
          <p class="text-[#1C2A3A]/70 text-sm leading-relaxed"><%= review.comment %></p>
        </div>
        <% }) %>
        <% } else { %>
        <p class="text-[#1C2A3A]/50 text-sm italic">No reviews yet. Be the first to share your experience!</p>
        <% } %>
      </div>
    </section>
    <% } %>
    </div>

    <!-- Right Column: Sticky Booking Panel -->
    <div class="lg:col-span-4">
      <div class="sticky top-32 space-y-8 animate-slide-up">
        <!-- Pricing & Quick Info Card -->
        <div class="bg-theme-surface/90 backdrop-blur-3xl rounded-[3rem] p-10 card-shadow border border-white/10 transition-all-300 hover:shadow-2xl">
          <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold tracking-tight mb-3 text-theme-dark text-center"><%= event.title%></h1>
            <div class="flex items-center justify-center space-x-2 text-apple-secondary text-sm">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span class="text-center truncate"><%= venue.address%></span>
            </div>
          </div>

          <div class="space-y-4 mb-10">
            <div class="flex justify-between items-center py-3 border-b border-white/10">
              <span class="text-sm font-medium text-apple-secondary text-left">Date</span>
              <span class="font-semibold text-theme-dark text-right"><%= schedule.date%></span>
            </div>
            <div class="flex justify-between items-center py-3 border-b border-white/10">
              <span class="text-sm font-medium text-apple-secondary text-left">Time</span>
              <span class="font-semibold text-theme-dark text-right"><%= schedule.time%></span>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-sm font-medium text-apple-secondary text-left">Price</span>
              <% if (ticket.lowestPrice > 0) { %>
              <span class="text-2xl font-bold text-theme-primary text-right">₹<%= ticket.lowestPrice %>.00</span>
              <% } else { %>
              <span class="text-lg font-semibold text-green-600 text-right">Free Entry</span>
              <% } %>
            </div>
          </div>

          <!-- ✅ Conditional: Show Tickets OR Reviews -->
          <% if (!isEventOver) { %>
          <!-- Ticket Selection (Event is ongoing/future) -->
          <div class="space-y-6 mb-8">
            <div class="flex items-center justify-between">
              <p class="text-xs font-bold uppercase tracking-widest text-apple-secondary text-left">Experiences</p>
              <p class="text-xs font-medium text-theme-primary bg-theme-primary/10 px-3 py-1 rounded-full"><%=ticket.ticketsLeft%> of <%=ticket.totalTickets%> tickets left </p>
            </div>
            <div class="grid grid-cols-1 gap-4">
              <% for (let i = 0; i < event.ticketTypes.length; i++) { 
                        const total = event.ticketTypes[i].quantityTotal;
                        const available = event.ticketTypes[i].quantityAvailable;
                        const sold = total - available;
                        const percentage = total > 0 ? (sold / total) * 100 : 0;
                        const isLowStock = percentage > 70;
                    %>
              <label class="relative flex flex-col p-5 bg-white/40 border border-white/40 rounded-2xl cursor-pointer hover:border-theme-primary/40 hover:bg-white/60 hover:shadow-md transition-all-300 group">
                <div class="flex items-center justify-between w-full mb-3">
                  <div class="flex items-center space-x-3">
                    <div class="p-2 bg-theme-primary/10 rounded-lg text-theme-primary group-hover:bg-theme-primary group-hover:text-white transition-all-300 flex-shrink-0">
                      <i class="fas fa-chair text-sm"></i>
                    </div>
                    <span class="text-sm font-bold text-[#1C2A3A]"><%= event.ticketTypes[i].name %></span>
                  </div>
                  <span class="text-lg font-bold text-[#1C2A3A] flex-shrink-0">₹<%= event.ticketTypes[i].price %></span>
                </div>

                <div class="w-full">
                  <div class="flex justify-between text-[10px] font-semibold uppercase tracking-wide mb-1 text-apple-secondary">
                    <span><%= available %> Seats Left of <%= total %></span>
                    <% if(isLowStock) { %>
                    <span class="text-red-500">Selling Fast</span>
                    <% } %>
                  </div>
                  <div class="progress-bg">
                    <div class="progress-fill <%= isLowStock ? 'bg-red-500' : 'bg-theme-primary' %>" style="width: <%= percentage %>%"></div>
                  </div>
                </div>
              </label>
              <% } %>
            </div>
          </div>

          <!-- Book Tickets Button -->
          <a href="/bookTickets/<%= event._id %>">
            <button class="w-full h-16 bg-theme-primary text-white rounded-[1.5rem] font-bold text-lg hover:bg-theme-dark hover:shadow-lg hover:-translate-y-1 active:translate-y-0 transition-all-300 card-shadow flex items-center justify-center gap-2 group">
              BOOK TICKETS
              <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </button>
          </a>

          <% } else { %>
          <!-- ✅ Event Over: Show Review Call-to-Action -->
          <div class="text-center py-8">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-green-100 flex items-center justify-center">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-theme-dark mb-2">Event Completed!</h3>
            <p class="text-apple-secondary text-sm mb-6">Share your experience with others</p>

            <% if (currentUserId) { %>
            <button onclick="openAddReviewModal()" class="w-full h-14 bg-[#ED8842] text-white rounded-[1.5rem] font-bold text-sm hover:bg-[#1C2A3A] transition-all-300 flex items-center justify-center gap-2">
              <i class="fas fa-star"></i> Write a Review
            </button>
            <% } else { %>
            <a href="/login?redirect=<%= encodeURIComponent('/event/' + event._id) %>" class="w-full h-14 bg-[#ED8842] text-white rounded-[1.5rem] font-bold text-sm hover:bg-[#1C2A3A] transition-all-300 flex items-center justify-center gap-2">
              <i class="fas fa-sign-in-alt"></i> Login to Review
            </a>
            <% } %>
          </div>
          <% } %>
        </div>

        <!-- Organizer Section -->
        <div class="bg-white/30 backdrop-blur-md rounded-[2rem] p-6 border border-white/40 transition-all-300 hover:bg-white/50">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-theme-primary to-theme-accent flex items-center justify-center text-white text-lg font-bold shadow-lg flex-shrink-0 overflow-hidden">
              <img src="<%= event.hostId.avatarUrl %>" class="w-full h-full object-cover rounded-full" alt="Host Avatar">
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[10px] font-bold text-apple-secondary uppercase tracking-wider mb-0.5 text-left">Organised By</p>
              <h3 class="font-bold text-theme-dark text-sm text-left truncate"><%= event.hostId.firstName + " " + event.hostId.lastName %></h3>
              <div class="flex items-center gap-1 text-[10px] text-green-600 font-medium mt-1">
                <i class="fas fa-check-circle"></i>
                <span>Verified Organiser</span>
              </div>
            </div>
            <a href="https://mail.google.com/mail/?view=cm&fs=1&to=<%= event.hostId.emailAddress%>&su=Inquiry about <%= event.title %>" target="_blank" class="w-10 h-10 rounded-full border border-gray-200 flex items-center justify-center text-gray-400 hover:bg-theme-primary hover:text-white hover:border-theme-primary transition-all-300 flex-shrink-0" title="Send Email">
              <i class="fas fa-envelope text-xs"></i>
            </a>
          </div>
        </div>

        <!-- Terms Mini -->
        <div class="px-8 py-6 bg-theme-surface/20 border border-white/10 rounded-[2rem] text-xs text-apple-secondary leading-relaxed transition-all-300 hover:bg-theme-surface/40">
          <p class="font-bold text-theme-dark mb-2 flex items-center gap-2 text-left">
            <i class="fas fa-shield-alt"></i> Notice
          </p>
          <p class="text-left">21+ only. ID verification required at entry. Prohibited items include professional cameras and outside drinks.</p>
        </div>
      </div>
    </div>
    </div>
  </main>

  <!-- Floating CTA for Mobile -->
  <div class="md:hidden fixed bottom-6 left-6 right-6 z-50">
    <% if (!isEventOver) { %>
    <a href="/bookTickets/<%= event._id %>">
      <button class="w-full h-16 bg-theme-primary text-white rounded-2xl font-semibold card-shadow text-lg shadow-xl hover:bg-theme-dark transition-all-300 flex items-center justify-center gap-2">
        Book Tickets <i class="fas fa-arrow-right text-sm"></i>
      </button>
    </a>
    <% } else if (currentUserId) { %>
    <button onclick="openAddReviewModal()" class="w-full h-16 bg-[#ED8842] text-white rounded-2xl font-semibold card-shadow text-lg shadow-xl hover:bg-[#1C2A3A] transition-all-300 flex items-center justify-center gap-2">
      Write a Review <i class="fas fa-star text-sm"></i>
    </button>
    <% } %>
