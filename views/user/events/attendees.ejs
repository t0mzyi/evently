<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event?.title || 'Event' %> Attendees — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            heading: ['Fraunces', 'serif'],
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            'apple-bg': '#EAE0CF',
            'apple-card': 'rgba(255, 255, 255, 0.6)',
            'apple-text': '#1C2A3A',
            'status-valid': '#10B981',
            'status-cancelled': '#EF4444',
            'status-used': '#6B7280',
          }
        }
      }
    }
  </script>
  <style>
    @media (hover: hover) {
      .card-hover:hover {
        transform: translateY(-2px);
        transition: all 0.2s ease;
      }

      .table-row:hover {
        background-color: rgba(255, 255, 255, 0.5);
      }
    }

    .search-highlight {
      background-color: #fef08a;
      padding: 0 2px;
      border-radius: 2px;
    }

    .status-badge {
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
      }

      70% {
        box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
      }

      100% {
        box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
      }
    }
  </style>
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">

  <%- include('../../partials/navbar') %>

  <!-- Sidebar - Full height, dark theme -->
  <aside class="w-20 shrink-0 hidden lg:block fixed left-0 top-0 h-screen z-40">
    <div class="bg-[#1C2A3A] h-full flex flex-col items-center py-8 border-r border-white/10">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-white/20 to-white/10 flex items-center justify-center text-white font-bold mb-8">E</div>
      <nav class="space-y-4 flex-1 flex flex-col justify-center w-full px-3">
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Profile">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Profile</span>
        </a>
        <a href="/dashboard/hostDashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-white/15 border border-white/20 text-white transition-all group relative" title="Dashboard">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Dashboard</span>
        </a>
        <a href="/dashboard/myBookings" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Bookings">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Bookings</span>
        </a>
        <a href="/dashboard/calendar" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Calendar">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Calendar</span>
        </a>
        <a href="/dashboard/wallet" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Wallet">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Wallet</span>
        </a>
      </nav>
      <div class="pt-6 border-t border-white/10 mt-auto w-full px-3 space-y-3">
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-gradient-to-br from-white/20 to-white/10 text-white text-xs font-bold" title="<%= user?.name || 'User' %>"><%= user?.name?.charAt(0) || 'U' %></a>
        <a href="/logout" class="w-full aspect-square flex items-center justify-center rounded-xl text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-all group relative" title="Logout">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Logout</span>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="pt-32 pb-16 px-6 lg:ml-20">
    <div class="max-w-7xl mx-auto">

      <!-- Header -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
          <a href="/view-event?id=<%= event?._id %>" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-[#1C2A3A]/60 hover:text-[#1C2A3A] transition-colors mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Event
          </a>
          <h1 class="text-4xl font-heading text-[#1C2A3A] mb-2"><%= event?.title || 'Event' %> Attendees</h1>
          <p class="text-[#1C2A3A]/60 font-sans"><%= event?.venueDetails?.city || 'Location' %> • <span id="totalAttendeesCount"><%= eventTickets?.length || 0 %></span> Registered</p>
        </div>
        <button onclick="exportAttendees()" class="px-6 py-3 bg-[#1C2A3A] text-white rounded-xl font-medium shadow-lg hover:bg-[#2C3E50] transition-all flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
            </path>
          </svg>
          Export List
        </button>
      </div>

      <!-- Filters & Search -->
      <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 mb-8 card-hover">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
          <!-- Search -->
          <div class="md:col-span-2">
            <label class="block text-xs font-medium text-[#1C2A3A]/60 mb-2">Search Attendees</label>
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#1C2A3A]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input type="text" id="attendeeSearch" placeholder="Search by name, email, or ticket ID..." class="w-full bg-white border border-[#1C2A3A]/10 rounded-xl pl-10 pr-10 py-2.5 text-sm text-[#1C2A3A] placeholder-[#1C2A3A]/30 focus:outline-none focus:border-[#1C2A3A]/20 transition-all" oninput="handleSearch(this.value)">
              <button id="clearSearch" onclick="clearSearch()" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#1C2A3A]/40 hover:text-[#1C2A3A] transition-colors hidden">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
          </div>

          <!-- Ticket Type Filter -->
          <div>
            <label class="block text-xs font-medium text-[#1C2A3A]/60 mb-2">Ticket Type</label>
            <select id="ticketTypeFilter" onchange="applyFilters()" class="w-full bg-white border border-[#1C2A3A]/10 rounded-xl px-4 py-2.5 text-sm text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A]/20 transition-all">
              <option value="">All Types</option>
              <% for(let i = 0; i < (event?.ticketTypes || []).length; i++) { %>
              <option value="<%= event.ticketTypes[i]._id %>"><%= event.ticketTypes[i].name %></option>
              <% } %>
            </select>
          </div>

          <!-- Status Filter -->
          <div>
            <label class="block text-xs font-medium text-[#1C2A3A]/60 mb-2">Status</label>
            <select id="statusFilter" onchange="applyFilters()" class="w-full bg-white border border-[#1C2A3A]/10 rounded-xl px-4 py-2.5 text-sm text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A]/20 transition-all">
              <option value="">All Status</option>
              <option value="VALID">Valid</option>
              <option value="CANCELLED">Cancelled</option>
              <option value="USED">Used</option>
            </select>
          </div>
        </div>

        <!-- Sort & Results Info -->
        <div class="flex flex-col md:flex-row justify-between items-center mt-4 pt-4 border-t border-[#1C2A3A]/10">
          <div class="flex items-center gap-3 mb-3 md:mb-0">
            <label class="text-xs font-medium text-[#1C2A3A]/60">Sort by:</label>
            <select id="sortSelect" onchange="applySort()" class="bg-white border border-[#1C2A3A]/10 rounded-lg px-3 py-1.5 text-sm text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A]/20 transition-all">
              <option value="date-desc">Newest First</option>
              <option value="date-asc">Oldest First</option>
              <option value="name-asc">Name A-Z</option>
              <option value="name-desc">Name Z-A</option>
              <option value="ticket-asc">Ticket Type A-Z</option>
            </select>
          </div>
          <p class="text-sm text-[#1C2A3A]/60">
            Showing <span id="visibleCount"><%= eventTickets?.length || 0 %></span> of <span id="totalCount"><%= eventTickets?.length || 0 %></span> attendees
          </p>
        </div>
      </div>

      <!-- Stats Overview -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-blue-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                </path>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-heading text-[#1C2A3A]" id="statTotal"><%= eventTickets?.length || 0 %></p>
              <p class="text-xs text-[#1C2A3A]/60 font-medium">Total Registered</p>
            </div>
          </div>
        </div>

        <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-purple-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z">
                </path>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-heading text-[#1C2A3A]" id="statPaid"><%= (eventTickets || []).filter(t => t.ticketTypeId && !t.isFree).length %></p>
              <p class="text-xs text-[#1C2A3A]/60 font-medium">Paid Tickets</p>
            </div>
          </div>
        </div>

        <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-emerald-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M12 12h.01m-6.97 2.994A12.05 12.05 0 0112 17.25c2.816 0 5.446-.83 7.675-2.247a.5.5 0 01.381-.058 11.935 11.935 0 003.256-1.145.5.5 0 01.564.564 11.93 11.93 0 00-1.145 3.256.5.5 0 01-.058.381A12.05 12.05 0 0120.25 12c0 2.816-.83 5.446-2.247 7.675a.5.5 0 01-.564.381 11.93 11.93 0 00-3.256-1.145.5.5 0 01-.381-.564A12.05 12.05 0 0112 3.75c1.11 0 2.08.402 2.599 1"></path>
              </svg>
            </div>
            <div>
              <p class="text-2xl font-heading text-emerald-700">₹<%= (eventTickets || []).reduce((sum, t) => sum + (t.hostRevenue || 0), 0).toLocaleString() %></p>
              <p class="text-xs text-emerald-600 font-medium">Your Revenue</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Attendees List Table -->
      <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] shadow-sm border border-white/40 overflow-hidden card-hover">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-[#1C2A3A]/5 border-b border-[#1C2A3A]/10">
              <tr>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Attendee</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Email</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Ticket</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Seat</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Purchased</th>
                <th class="text-left px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Status</th>
                <th class="text-right px-6 py-4 text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60">Revenue</th>
              </tr>
            </thead>
            <tbody id="attendeesTableBody" class="divide-y divide-[#1C2A3A]/5">
              <!-- Dynamically populated by JavaScript -->
            </tbody>
          </table>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="hidden text-center py-12 px-6">
          <svg class="w-12 h-12 mx-auto text-[#1C2A3A]/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
          <p class="text-[#1C2A3A]/60 mb-2">No attendees match your filters</p>
          <button onclick="clearAllFilters()" class="text-sm text-[#1C2A3A] hover:underline">Clear all filters</button>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between px-6 py-4 border-t border-[#1C2A3A]/10" id="pagination">
          <p class="text-sm text-[#1C2A3A]/60">Showing <span id="pageStart">1</span>-<span id="pageEnd">10</span> of <span id="pageTotal"><%= eventTickets?.length || 0 %></span> attendees</p>
          <div class="flex gap-2">
            <button id="prevBtn" onclick="changePage(-1)" disabled class="px-4 py-2 border border-[#1C2A3A]/20 text-[#1C2A3A]/40 rounded-lg text-sm font-medium cursor-not-allowed">
              Previous
            </button>
            <button id="nextBtn" onclick="changePage(1)" class="px-4 py-2 bg-[#1C2A3A] text-white rounded-lg text-sm font-medium hover:bg-[#2C3E50] transition-all">
              Next
            </button>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- JavaScript for Dynamic Functionality -->
  <script id="page-data" type="application/json">
    {
      "eventTickets": <%- JSON.stringify(eventTickets || []) %>,
      "ticketTypes": <%- JSON.stringify(event?.ticketTypes || []) %>
    }
  </script>

  <script>
    // Parse embedded data safely
    let allAttendees = [];
    let ticketTypesMap = {};

    try {
      const dataEl = document.getElementById('page-data');
      if (dataEl?.textContent) {
        const parsed = JSON.parse(dataEl.textContent);
        allAttendees = parsed.eventTickets || [];
        (parsed.ticketTypes || []).forEach(tt => {
          ticketTypesMap[tt._id] = tt.name;
        });
      }
    } catch (e) {
      console.warn('Could not parse page data:', e);
    }

    // State
    let filteredAttendees = [...allAttendees];
    let currentPage = 1;
    const itemsPerPage = 10;
    let searchQuery = '';
    let ticketTypeFilter = '';
    let statusFilter = '';
    let sortBy = 'date-desc';

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      updateStats();
      applyFilters();
    });

    // Search functionality
    function handleSearch(query) {
      searchQuery = query.trim().toLowerCase();
      const clearBtn = document.getElementById('clearSearch');
      if (searchQuery.length > 0) {
        clearBtn.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
      }
      applyFilters();
    }

    function clearSearch() {
      document.getElementById('attendeeSearch').value = '';
      searchQuery = '';
      document.getElementById('clearSearch').classList.add('hidden');
      applyFilters();
    }

    // Filter & Sort
    function applyFilters() {
      ticketTypeFilter = document.getElementById('ticketTypeFilter').value;
      statusFilter = document.getElementById('statusFilter').value;

      filteredAttendees = allAttendees.filter(ticket => {
        // Search filter
        if (searchQuery) {
          const fields = [
            ticket.holderDetails?.firstName?.toLowerCase(),
            ticket.holderDetails?.lastName?.toLowerCase(),
            ticket.holderDetails?.email?.toLowerCase(),
            ticket.ticketId?.toLowerCase(),
            `${ticket.seatTier}${ticket.seatNumber}`.toLowerCase()
          ].filter(Boolean);
          if (!fields.some(f => f.includes(searchQuery))) return false;
        }

        // Ticket type filter
        if (ticketTypeFilter && ticket.ticketTypeId?.toString() !== ticketTypeFilter) return false;

        // Status filter
        if (statusFilter && ticket.status !== statusFilter) return false;

        return true;
      });

      applySort();
    }

    function applySort() {
      sortBy = document.getElementById('sortSelect').value;

      filteredAttendees.sort((a, b) => {
        switch (sortBy) {
          case 'date-asc':
            return new Date(a.createdAt) - new Date(b.createdAt);
          case 'date-desc':
            return new Date(b.createdAt) - new Date(a.createdAt);
          case 'name-asc':
            return (a.holderDetails?.firstName || '').localeCompare(b.holderDetails?.firstName || '');
          case 'name-desc':
            return (b.holderDetails?.firstName || '').localeCompare(a.holderDetails?.firstName || '');
          case 'ticket-asc':
            return (ticketTypesMap[a.ticketTypeId] || '').localeCompare(ticketTypesMap[b.ticketTypeId] || '');
          default:
            return 0;
        }
      });

      currentPage = 1;
      renderTable();
      updatePagination();
      updateCounts();
    }

    // Render table
    function renderTable() {
      const tbody = document.getElementById('attendeesTableBody');
      const emptyState = document.getElementById('emptyState');
      const pagination = document.getElementById('pagination');

      if (filteredAttendees.length === 0) {
        tbody.innerHTML = '';
        emptyState.classList.remove('hidden');
        pagination.classList.add('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      pagination.classList.remove('hidden');

      const start = (currentPage - 1) * itemsPerPage;
      const end = start + itemsPerPage;
      const pageItems = filteredAttendees.slice(start, end);

      tbody.innerHTML = pageItems.map(ticket => {
        const avatarUrl = ticket.userId?.avatarUrl;
        const firstName = ticket.holderDetails?.firstName || 'U';
        const lastName = ticket.holderDetails?.lastName || '';
        const email = ticket.holderDetails?.email || '';
        const ticketName = ticket.ticketName || ticketTypesMap[ticket.ticketTypeId] || 'Unknown';
        const isFree = ticket.purchasePrice === 0 || ticket.isFree;
        const purchaseDate = new Date(ticket.createdAt).toLocaleDateString('en-US', {
          month: 'short',
          day: 'numeric',
          year: 'numeric'
        });

        // Avatar with fallback
        const avatarHTML = avatarUrl && avatarUrl.trim() !== '' ?
          `<img src="${avatarUrl}" alt="${firstName}" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<span>${firstName.charAt(0).toUpperCase()}</span>';">` :
          `<span>${firstName.charAt(0).toUpperCase()}</span>`;

        // Status badge
        const statusConfig = {
          'VALID': {
            bg: 'bg-emerald-50',
            text: 'text-emerald-700',
            label: 'Valid',
            pulse: true
          },
          'CANCELLED': {
            bg: 'bg-red-50',
            text: 'text-red-700',
            label: 'Cancelled',
            pulse: false
          },
          'USED': {
            bg: 'bg-gray-50',
            text: 'text-gray-700',
            label: 'Used',
            pulse: false
          }
        };
        const status = statusConfig[ticket.status] || statusConfig['VALID'];

        return `
                    <tr class="table-row transition-colors">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-[#1C2A3A] flex items-center justify-center text-white font-bold overflow-hidden flex-shrink-0">
                                    ${avatarHTML}
                                </div>
                                <div>
                                    <p class="font-medium text-[#1C2A3A]">${firstName} ${lastName}</p>
                                    <p class="text-xs text-[#1C2A3A]/60">ID: ${ticket.ticketId}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-[#1C2A3A]/70">${email}</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${isFree ? 'bg-emerald-50 text-emerald-700' : 'bg-purple-50 text-purple-700'} rounded-full text-xs font-medium">
                                ${ticketName}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-sm text-[#1C2A3A]/70">${ticket.seatTier}${ticket.seatNumber}</td>
                        <td class="px-6 py-4 text-sm text-[#1C2A3A]/70">${purchaseDate}</td>
                        <td class="px-6 py-4">
                            <span class="px-3 py-1 ${status.bg} ${status.text} rounded-full text-xs font-medium ${status.pulse ? 'status-badge' : ''}">
                                ${status.label}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            ${isFree 
                                ? '<span class="text-xs text-emerald-600 font-medium">Free</span>'
                                : `<div class="text-sm font-medium text-[#1C2A3A]">₹${ticket.purchasePrice}</div>
                                   <div class="text-xs text-emerald-600">+₹${ticket.hostRevenue}</div>`
                            }
                        </td>
                    </tr>
                `;
      }).join('');
    }

    // Pagination
    function updatePagination() {
      const totalPages = Math.ceil(filteredAttendees.length / itemsPerPage);
      const start = (currentPage - 1) * itemsPerPage + 1;
      const end = Math.min(currentPage * itemsPerPage, filteredAttendees.length);

      document.getElementById('pageStart').textContent = filteredAttendees.length > 0 ? start : 0;
      document.getElementById('pageEnd').textContent = end;
      document.getElementById('pageTotal').textContent = filteredAttendees.length;

      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');

      prevBtn.disabled = currentPage === 1;
      prevBtn.classList.toggle('cursor-not-allowed', currentPage === 1);
      prevBtn.classList.toggle('text-[#1C2A3A]/40', currentPage === 1);
      prevBtn.classList.toggle('text-[#1C2A3A]', currentPage > 1);

      nextBtn.disabled = currentPage >= totalPages;
      nextBtn.classList.toggle('cursor-not-allowed', currentPage >= totalPages);
      nextBtn.classList.toggle('bg-[#1C2A3A]/40', currentPage >= totalPages);
      nextBtn.classList.toggle('bg-[#1C2A3A]', currentPage < totalPages);
    }

    function changePage(delta) {
      const totalPages = Math.ceil(filteredAttendees.length / itemsPerPage);
      const newPage = currentPage + delta;
      if (newPage >= 1 && newPage <= totalPages) {
        currentPage = newPage;
        renderTable();
        updatePagination();
        // Scroll to top of table
        document.querySelector('.overflow-x-auto')?.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    }

    // Update counts
    function updateCounts() {
      document.getElementById('visibleCount').textContent = filteredAttendees.length;
      document.getElementById('totalCount').textContent = allAttendees.length;
    }

    function updateStats() {
      document.getElementById('statTotal').textContent = allAttendees.length;
      const paidCount = allAttendees.filter(t => t.ticketTypeId && !t.isFree).length;
      document.getElementById('statPaid').textContent = paidCount;
    }

    function clearAllFilters() {
      document.getElementById('attendeeSearch').value = '';
      document.getElementById('ticketTypeFilter').value = '';
      document.getElementById('statusFilter').value = '';
      document.getElementById('sortSelect').value = 'date-desc';
      searchQuery = '';
      ticketTypeFilter = '';
      statusFilter = '';
      sortBy = 'date-desc';
      document.getElementById('clearSearch').classList.add('hidden');
      applyFilters();
    }

    // Export functionality (placeholder)
    function exportAttendees() {
      const data = filteredAttendees.map(t => ({
        name: `${t.holderDetails?.firstName} ${t.holderDetails?.lastName}`,
        email: t.holderDetails?.email,
        ticket: t.ticketName || ticketTypesMap[t.ticketTypeId],
        seat: `${t.seatTier}${t.seatNumber}`,
        status: t.status,
        revenue: t.hostRevenue,
        purchased: new Date(t.createdAt).toLocaleDateString()
      }));

      const csv = [
        ['Name', 'Email', 'Ticket', 'Seat', 'Status', 'Revenue', 'Purchased'].join(','),
        ...data.map(row => [
          `"${row.name}"`,
          `"${row.email}"`,
          `"${row.ticket}"`,
          `"${row.seat}"`,
          `"${row.status}"`,
          row.revenue,
          `"${row.purchased}"`
        ].join(','))
      ].join('\n');

      const blob = new Blob([csv], {
        type: 'text/csv'
      });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `attendees-<%= event?._id %>.csv`;
      a.click();
      URL.revokeObjectURL(url);
    }
  </script>
</body>

</html>