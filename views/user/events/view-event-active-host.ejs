<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= event.title %> (Host View) — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            heading: ['Fraunces', 'serif'],
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            'apple-bg': '#EAE0CF',
            'apple-card': 'rgba(255, 255, 255, 0.6)',
            'apple-text': '#1C2A3A',
            'revenue-highlight': '#2C3E50',
          },
          animation: {
            'pop-in': 'popIn 0.3s ease-out forwards',
            'float': 'float 3s ease-in-out infinite',
          },
          keyframes: {
            popIn: {
              '0%': {
                opacity: '0',
                transform: 'translateY(20px) scale(0.95)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0) scale(1)'
              }
            },
            float: {
              '0%, 100%': {
                transform: 'translateY(0)'
              },
              '50%': {
                transform: 'translateY(-8px)'
              }
            }
          }
        }
      }
    }
  </script>
  <style>
    @media (hover: hover) {
      .card-hover:hover {
        transform: translateY(-2px);
        transition: all 0.2s ease;
      }
    }

    /* Smooth scroll behavior */
    html {
      scroll-behavior: smooth;
    }

    /* Hide scrollbar for Chrome/Safari/Opera but keep functionality */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Search highlight */
    .search-highlight {
      background-color: #fef08a;
      padding: 0 3px;
      border-radius: 3px;
      font-weight: 500;
    }

    /* Floating button pulse animation */
    @keyframes pulse-ring {
      0% {
        transform: scale(0.8);
        opacity: 1;
      }

      100% {
        transform: scale(1.3);
        opacity: 0;
      }
    }

    .pulse-ring::before {
      content: '';
      position: absolute;
      inset: -4px;
      border: 2px solid currentColor;
      border-radius: 9999px;
      animation: pulse-ring 1.5s ease-out infinite;
    }
  </style>
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">

  <!-- Global Navigation -->
  <%- include('../../partials/navbar') %>
  <%- include('../../partials/toast') %>
  <%- include('../../partials/doodles') %>

  <!-- Sidebar -->
  <aside class="w-20 shrink-0 hidden lg:block fixed left-0 top-0 h-screen z-40">
    <div class="bg-[#1C2A3A] h-full flex flex-col items-center py-8 border-r border-white/10">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-white/20 to-white/10 flex items-center justify-center text-white font-bold mb-8">E</div>
      <nav class="space-y-4 flex-1 flex flex-col justify-center w-full px-3">
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Profile">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Profile</span>
        </a>
        <a href="/dashboard/hostDashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-white/15 border border-white/20 text-white transition-all group relative" title="Dashboard">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Dashboard</span>
        </a>
        <a href="/dashboard/myBookings" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Bookings">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Bookings</span>
        </a>
        <a href="/dashboard/calendar" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Calendar">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Calendar</span>
        </a>
        <a href="/dashboard/wallet" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Wallet">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Wallet</span>
        </a>
      </nav>
      <div class="pt-6 border-t border-white/10 mt-auto w-full px-3 space-y-3">
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-gradient-to-br from-white/20 to-white/10 text-white text-xs font-bold" title="<%= user?.name || 'User' %>"><%= user?.name?.charAt(0) || 'U' %></a>
        <a href="/logout" class="w-full aspect-square flex items-center justify-center rounded-xl text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-all group relative" title="Logout">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Logout</span>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="pt-32 pb-16 px-6 lg:ml-20">
    <div class="max-w-7xl mx-auto">

      <!-- Back Button & Actions -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <a href="/dashboard/hostDashboard" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-[#1C2A3A]/60 hover:text-[#1C2A3A] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Dashboard
        </a>
        <div class="flex flex-wrap gap-3">
          <a href="/editEvent/<%=event._id%>" class="px-6 py-3 bg-[#1C2A3A] text-white rounded-xl font-medium shadow-sm hover:bg-[#2C3E50] transition-all flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Edit Event
          </a>
        </div>
      </div>

      <!-- Two Column Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Left Column - Main Content -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Event Header Card -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] overflow-hidden shadow-sm border border-white/40 card-hover">
            <div class="relative h-64 overflow-hidden">
              <img src="<%=event.galleryImages[0]%>" class="w-full h-full object-cover" alt="<%= event.title %>">
              <div class="absolute inset-0 bg-gradient-to-t from-[#1C2A3A]/60 to-transparent"></div>
              <% if(event.status == 'approved') {%>
              <div class="absolute top-4 left-4 bg-emerald-500/90 backdrop-blur-md px-3 py-1.5 rounded-full">
                <span class="text-[10px] font-bold text-white uppercase tracking-widest">Approved</span>
              </div>
              <%} else if(event.status == 'pending') {%>
              <div class="absolute top-4 left-4 bg-yellow-500/90 backdrop-blur-md px-3 py-1.5 rounded-full">
                <span class="text-[10px] font-bold text-white uppercase tracking-widest">Pending</span>
              </div>
              <%} else if(event.status == 'rejected') {%>
              <div class="absolute top-4 left-4 bg-red-500/90 backdrop-blur-md px-3 py-1.5 rounded-full">
                <span class="text-[10px] font-bold text-white uppercase tracking-widest">Rejected</span>
              </div>
              <%} else if(event.status == 'live') {%>
              <div class="absolute top-4 left-4 bg-purple-500/90 backdrop-blur-md px-3 py-1.5 rounded-full">
                <span class="text-[10px] font-bold text-white uppercase tracking-widest">Live</span>
              </div>
              <%}%>
            </div>
            <div class="p-6">
              <h1 class="text-3xl font-heading text-[#1C2A3A] mb-4"><%= event.title %></h1>
              <div class="space-y-3 mb-6">
                <div class="flex items-center gap-2.5 text-[#1C2A3A]/70">
                  <svg class="w-4 h-4 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                  <span class="text-sm font-medium"><%= event.sDate.date %> to <%= event.eDate.date %></span>
                </div>
                <div class="flex items-center gap-2.5 text-[#1C2A3A]/70">
                  <svg class="w-4 h-4 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="text-sm font-medium"><%= event.sDate.time %> - <%= event.eDate.time %></span>
                </div>
              </div>
            </div>
            <div class="border-t border-[#1C2A3A]/10 p-6">
              <h2 class="text-lg font-heading text-[#1C2A3A] mb-3">About This Event</h2>
              <p class="text-sm text-[#1C2A3A]/70 leading-relaxed"><%= event.description %></p>
            </div>
            <div class="border-t border-[#1C2A3A]/10 p-6">
              <h2 class="text-lg font-heading text-[#1C2A3A] mb-4">Event Gallery</h2>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <% for(let i = 1 ; i< event.galleryImages.length ;i++){%>
                <div class="aspect-square rounded-xl overflow-hidden bg-gray-100 cursor-pointer hover:opacity-90 transition-opacity">
                  <img src="<%= event.galleryImages[i] %>" class="w-full h-full object-cover">
                </div>
                <%}%>
              </div>
            </div>
          </div>

          <!-- Ticket Information Card -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
            <h2 class="text-lg font-heading text-[#1C2A3A] mb-4">Ticket Types</h2>
            <div class="space-y-3">
              <% for(let i = 0 ; i <  event.ticketTypes.length ;i++ ) {%>
                <div class="bg-[#F9F7F5] rounded-xl p-4">
                  <div class="flex justify-between items-start mb-1.5">
                    <div>
                      <h3 class="font-heading text-base text-[#1C2A3A] mb-1"><%= event.ticketTypes[i].name%></h3>
                      <p class="text-xs text-[#1C2A3A]/60"><%= event.ticketTypes[i].description %></p>
                      <p class="text-xs text-[#1C2A3A]/60"><%= event.ticketTypes[i].quantityAvailable %> of <%= event.ticketTypes[i].quantityTotal %> tickets left</p>
                    </div>
                    <span class="text-xl font-heading text-[#1C2A3A]">₹<%= event.ticketTypes[i].price %></span>
                  </div>
                </div>
                <%}%>
            </div>
          </div>

          <!-- Financial Summary Card -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
            <h2 class="text-lg font-heading text-[#1C2A3A] mb-4">Financial Summary</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div class="bg-[#F9F7F5] rounded-xl p-4 text-center">
                <p class="text-2xl font-heading text-[#1C2A3A] font-bold">₹<%= (event.tickets.revenue || 0).toLocaleString() %></p>
                <p class="text-xs text-[#1C2A3A]/50 uppercase tracking-widest">Total Revenue</p>
              </div>
              <div class="bg-[#F9F7F5] rounded-xl p-4 text-center">
                <p class="text-2xl font-heading text-[#1C2A3A] font-bold"><%= event.tickets.sold %></p>
                <p class="text-xs text-[#1C2A3A]/50 uppercase tracking-widest">Tickets Sold</p>
              </div>
              <div class="bg-emerald-50 rounded-xl p-4 text-center border border-emerald-100">
                <p class="text-2xl font-heading text-emerald-700 font-bold">₹<%= (eventTickets?.reduce((sum, t) => sum + (t.hostRevenue || 0), 0) || 0).toLocaleString() %></p>
                <p class="text-xs text-emerald-600 uppercase tracking-widest">Your Earnings</p>
              </div>
            </div>
          </div>

          <!-- Scroll to Attendees Button (Pops in after stats) -->
          <div id="scrollToAttendeesBtn" class="hidden animate-pop-in">
            <button onclick="scrollToAttendees()" class="group w-full flex items-center justify-center gap-3 py-4 bg-gradient-to-r from-[#1C2A3A]/10 to-[#1C2A3A]/5 hover:from-[#1C2A3A]/20 hover:to-[#1C2A3A]/10 rounded-2xl border border-[#1C2A3A]/10 transition-all cursor-pointer">
              <div class="relative">
                <svg class="w-5 h-5 text-[#1C2A3A] group-hover:animate-bounce transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
                </svg>
                <div class="absolute inset-0 pulse-ring text-[#1C2A3A]/30"></div>
              </div>
              <span class="font-medium text-[#1C2A3A]">View All Attendees</span>
              <span class="text-xs text-[#1C2A3A]/50 bg-[#1C2A3A]/10 px-2 py-0.5 rounded-full"><%= event.tickets.sold %></span>
            </button>
          </div>

          <!-- ATTENDEES SECTION with Search -->
          <div id="attendeesSection" class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40 card-hover scroll-mt-24">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
              <div>
                <h2 class="text-lg font-heading text-[#1C2A3A]">Attendees (<span id="attendeeCount"><%= event.tickets.sold %></span>)</h2>
                <p class="text-sm text-[#1C2A3A]/50 mt-1">Total confirmed attendees</p>
              </div>
              <a href="/<%= event._id %>/attendees" class="px-5 py-2 bg-[#1C2A3A]/5 hover:bg-[#1C2A3A]/10 text-[#1C2A3A] text-xs font-bold uppercase tracking-wider rounded-full transition-colors inline-flex items-center gap-1.5">
                View Full List
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              </a>
            </div>

            <!-- Frontend Search Bar -->
            <div class="mb-6">
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-[#1C2A3A]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input type="text" id="attendeeSearch" placeholder="Search attendees by name, email, or ticket ID..." class="w-full bg-white/80 border border-[#1C2A3A]/10 rounded-xl pl-11 pr-10 py-3 text-sm text-[#1C2A3A] placeholder-[#1C2A3A]/40 focus:outline-none focus:ring-2 focus:ring-[#1C2A3A]/20 focus:border-[#1C2A3A]/30 transition-all" oninput="filterAttendees(this.value)">
                <button id="clearSearch" onclick="clearAttendeeSearch()" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#1C2A3A]/40 hover:text-[#1C2A3A] transition-colors hidden">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
              <p id="searchResults" class="text-xs text-[#1C2A3A]/50 mt-2 hidden">
                Showing <span id="visibleCount">0</span> of <span id="totalCount"><%= eventTickets?.length || 0 %></span> attendees
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-4 mb-6">
              <div class="flex -space-x-4">
                <% 
                  const displayedAttendees = eventTickets ? eventTickets.slice(0, 5) : [];
                %>
                <% for (let i = 0; i < displayedAttendees.length; i++) { 
                  const attendee = displayedAttendees[i];
                  const avatarUrl = attendee.userId?.avatarUrl;
                  const firstName = attendee.holderDetails?.firstName || 'U';
                %>
                <div class="w-14 h-14 rounded-full border-4 border-white bg-[#1C2A3A] shadow-lg relative z-<%= i %> hover:z-10 hover:scale-110 transition-transform cursor-pointer overflow-hidden attendee-avatar" data-name="<%= (attendee.holderDetails?.firstName + ' ' + attendee.holderDetails?.lastName).toLowerCase() %>" data-email="<%= attendee.holderDetails?.email?.toLowerCase() %>" data-ticket="<%= attendee.ticketId?.toLowerCase() %>">
                  <% if (avatarUrl && avatarUrl.trim() !== '') { %>
                  <img src="<%= avatarUrl %>" alt="<%= firstName %>" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<span class=\'text-white font-bold text-lg\'><%= firstName.charAt(0).toUpperCase() %></span>';">
                  <% } else { %>
                  <span class="text-white font-bold text-lg"><%= firstName.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <% } %>
                <% if (event.tickets.sold > 5) { %>
                <div class="w-14 h-14 rounded-full border-4 border-white bg-[#1C2A3A] flex items-center justify-center shadow-lg relative z-0 hover:z-10 hover:scale-110 transition-transform cursor-pointer">
                  <span class="text-white text-xs font-bold">+<%= event.tickets.sold - 5 %></span>
                </div>
                <% } %>
                <% if (displayedAttendees.length === 0) { %>
                <div class="w-14 h-14 rounded-full border-4 border-white bg-gray-300 flex items-center justify-center shadow-lg">
                  <span class="text-[#1C2A3A] text-xs font-bold">No</span>
                </div>
                <% } %>
              </div>
              <p class="text-sm text-[#1C2A3A]/60">confirmed attendees</p>
            </div>

            <!-- Recent Attendees List (Filtered) -->
            <div class="mt-6 border-t border-[#1C2A3A]/10 pt-6">
              <h3 class="text-sm font-medium text-[#1C2A3A]/70 mb-3">Recent Attendees</h3>
              <div id="attendeesList" class="space-y-3">
                <% 
                  const recentAttendees = eventTickets ? eventTickets.slice(0, 3) : [];
                  const totalAttendees = eventTickets ? eventTickets.length : 0;
                %>
                <% if (recentAttendees.length > 0) { %>
                <% for (let i = 0; i < recentAttendees.length; i++) { 
                    const attendee = recentAttendees[i];
                    const avatarUrl = attendee.userId?.avatarUrl;
                    const firstName = attendee.holderDetails?.firstName || 'User';
                    const lastName = attendee.holderDetails?.lastName || '';
                    const fullName = `${firstName} ${lastName}`.toLowerCase();
                    const email = attendee.holderDetails?.email?.toLowerCase() || '';
                    const ticketId = attendee.ticketId?.toLowerCase() || '';
                  %>
                <div class="attendee-item flex items-center justify-between p-3 bg-[#F9F7F5] rounded-xl transition-all" data-name="<%= fullName %>" data-email="<%= email %>" data-ticket="<%= ticketId %>">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#1C2A3A] flex items-center justify-center text-white text-sm font-bold overflow-hidden">
                      <% if (avatarUrl && avatarUrl.trim() !== '') { %>
                      <img src="<%= avatarUrl %>" alt="<%= firstName %>" class="w-full h-full object-cover" onerror="this.parentElement.innerHTML='<span><%= firstName.charAt(0).toUpperCase() %></span>';">
                      <% } else { %>
                      <span><%= firstName.charAt(0).toUpperCase() %></span>
                      <% } %>
                    </div>
                    <div>
                      <p class="font-medium text-[#1C2A3A] attendee-name"><%= firstName %> <%= lastName %></p>
                      <p class="text-xs text-[#1C2A3A]/50 attendee-email"><%= attendee.holderDetails?.email %> • Seat: <%= attendee.seatTier %><%= attendee.seatNumber %></p>
                    </div>
                  </div>
                  <div class="text-right">
                    <% if (attendee.ticketTypeId) { %>
                    <p class="font-medium text-[#1C2A3A]">₹<%= attendee.purchasePrice %></p>
                    <p class="text-xs text-emerald-600">+₹<%= attendee.hostRevenue %></p>
                    <% } else { %>
                    <span class="bg-emerald-50 text-emerald-700 text-xs px-2 py-0.5 rounded-full">Free</span>
                    <% } %>
                  </div>
                </div>
                <% } %>
                <% if (totalAttendees > 3) { %>
                <a href="/attendees?id=<%= event._id %>" class="block text-center py-3 text-sm text-[#1C2A3A]/60 hover:text-[#1C2A3A] font-medium">
                  View all <%= totalAttendees %> attendees
                </a>
                <% } %>
                <% } else { %>
                <div class="text-center py-6 bg-gray-50 rounded-xl">
                  <svg class="w-6 h-6 mx-auto text-[#1C2A3A]/30 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                  </svg>
                  <p class="text-sm text-[#1C2A3A]/50">No attendees yet</p>
                </div>
                <% } %>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Column - Stats & Info -->
        <div class="space-y-8">

          <!-- Venue & Location -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-full bg-[#1C2A3A] flex items-center justify-center text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <h2 class="text-lg font-heading text-[#1C2A3A]">Venue & Location</h2>
            </div>
            <div class="h-48 bg-gray-200 rounded-2xl overflow-hidden relative">
              <iframe class="w-full h-full" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?q=<%= encodeURIComponent(event.venueDetails.address) %>&t=&z=13&ie=UTF8&iwloc=&output=embed"></iframe>
            </div>
            <div class="mt-4">
              <h3 class="text-lg font-bold text-[#1C2A3A] mb-2"><%= event.venueDetails.name %></h3>
              <p class="text-sm text-[#1C2A3A]/70"><%= event.venueDetails.address %></p>
              <a href="https://www.google.com/maps/dir/?api=1&destination=<%= encodeURIComponent(event.venueDetails.address) %>" target="_blank" class="mt-3 inline-flex items-center gap-2 px-4 py-2 bg-[#1C2A3A] text-white text-xs font-bold rounded-xl hover:bg-[#2C3E50] transition-colors">
                Get Directions
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Event Statistics -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
            <h2 class="text-lg font-heading text-[#1C2A3A] mb-4">Event Statistics</h2>
            <div class="grid grid-cols-2 gap-3">
              <div class="text-center p-3 bg-[#F9F7F5] rounded-xl">
                <p class="text-2xl font-heading text-[#1C2A3A] font-bold"><%= event.tickets.sold %></p>
                <p class="text-[9px] uppercase tracking-widest text-[#1C2A3A]/40 font-bold">Sold</p>
              </div>
              <div class="text-center p-3 bg-[#F9F7F5] rounded-xl">
                <p class="text-2xl font-heading text-[#1C2A3A] font-bold"><%= event.tickets.remaining %></p>
                <p class="text-[9px] uppercase tracking-widest text-[#1C2A3A]/40 font-bold">Available</p>
              </div>
              <div class="text-center p-3 bg-[#F9F7F5] rounded-xl">
                <p class="text-2xl font-heading text-[#1C2A3A] font-bold">₹<%= (event.tickets.revenue || 0).toLocaleString() %></p>
                <p class="text-[9px] uppercase tracking-widest text-[#1C2A3A]/40 font-bold">Revenue</p>
              </div>
              <div class="text-center p-3 bg-emerald-50 rounded-xl border border-emerald-100">
                <p class="text-2xl font-heading text-emerald-700 font-bold"><%= Math.round((event.tickets.sold / event.tickets.total) * 100) %>%</p>
                <p class="text-[9px] uppercase tracking-widest text-emerald-600 font-bold">Capacity</p>
              </div>
            </div>
          </div>

          <!-- Reviews Summary -->
          <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40 card-hover">
            <h2 class="text-lg font-heading text-[#1C2A3A] mb-4">Reviews</h2>
            <div class="text-center">
              <span class="text-4xl font-heading font-bold text-[#1C2A3A]">4.8</span>
              <div class="flex justify-center text-yellow-500 gap-0.5 mt-1">
                <% for(let i=0; i<5; i++) { %>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <% } %>
              </div>
              <p class="text-xs text-[#1C2A3A]/50 mt-1">Based on 128 reviews</p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </main>

  <!-- JavaScript for Search & Scroll -->
  <script>
    // Show scroll button after page load with slight delay
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(() => {
        const scrollBtn = document.getElementById('scrollToAttendeesBtn');
        if (scrollBtn) {
          scrollBtn.classList.remove('hidden');
        }
      }, 800);

      // Initialize counts
      const totalAttendees = <%= eventTickets?.length || 0 %>;
      document.getElementById('totalCount').textContent = totalAttendees;
      document.getElementById('attendeeCount').textContent = <%= event.tickets.sold || 0 %>;
    });

    // Smooth scroll to attendees section
    function scrollToAttendees() {
      const attendeesSection = document.getElementById('attendeesSection');
      if (attendeesSection) {
        attendeesSection.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
        // Focus search input after scroll
        setTimeout(() => {
          document.getElementById('attendeeSearch')?.focus();
        }, 600);
      }
    }

    // Frontend search/filter functionality
    function filterAttendees(query) {
      const searchQuery = query.trim().toLowerCase();
      const clearBtn = document.getElementById('clearSearch');
      const searchResults = document.getElementById('searchResults');

      // Show/hide clear button
      if (searchQuery.length > 0) {
        clearBtn.classList.remove('hidden');
        searchResults.classList.remove('hidden');
      } else {
        clearBtn.classList.add('hidden');
        searchResults.classList.add('hidden');
      }

      // Get all attendee items
      const attendeeItems = document.querySelectorAll('.attendee-item, .attendee-avatar');
      let visibleCount = 0;

      attendeeItems.forEach(item => {
        const name = item.dataset.name || '';
        const email = item.dataset.email || '';
        const ticket = item.dataset.ticket || '';

        // Check if item matches search
        const matches = !searchQuery ||
          name.includes(searchQuery) ||
          email.includes(searchQuery) ||
          ticket.includes(searchQuery);

        if (matches) {
          item.classList.remove('hidden', 'opacity-50');
          item.style.display = '';
          visibleCount++;

          // Highlight matching text
          if (searchQuery && item.querySelector('.attendee-name')) {
            highlightText(item.querySelector('.attendee-name'), searchQuery);
            highlightText(item.querySelector('.attendee-email'), searchQuery);
          }
        } else {
          item.classList.add('hidden');
          item.style.display = 'none';
        }
      });

      // Update results count
      document.getElementById('visibleCount').textContent = visibleCount;

      // Show empty state if no results
      const emptyState = document.querySelector('#attendeesList .text-center');
      if (visibleCount === 0 && searchQuery) {
        if (emptyState) emptyState.classList.remove('hidden');
      } else if (emptyState) {
        emptyState.classList.add('hidden');
      }
    }

    // Clear search
    function clearAttendeeSearch() {
      const searchInput = document.getElementById('attendeeSearch');
      if (searchInput) {
        searchInput.value = '';
        filterAttendees('');
        searchInput.focus();
      }
    }

    // Helper: Highlight matching text in an element
    function highlightText(element, query) {
      if (!element || !query) return;

      const originalText = element.textContent;
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');

      if (regex.test(originalText)) {
        element.innerHTML = originalText.replace(regex, '<span class="search-highlight">$1</span>');
      }
    }

    // Allow Escape key to clear search
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const searchInput = document.getElementById('attendeeSearch');
        if (searchInput && document.activeElement === searchInput) {
          clearAttendeeSearch();
        }
      }
    });

    // Add click handler to avatar circles to trigger search
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.attendee-avatar').forEach(avatar => {
        avatar.addEventListener('click', function() {
          const name = this.dataset.name || '';
          const searchInput = document.getElementById('attendeeSearch');
          if (searchInput && name) {
            searchInput.value = name.split(' ')[0];
            filterAttendees(searchInput.value);
            scrollToAttendees();
          }
        });
      });
    });
  </script>
</body>

</html>