<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Event Analytics — Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600&family=Inter:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/styles.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        heading: ['Fraunces', 'serif'],
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        'apple-bg': '#EAE0CF',
                        'apple-card': 'rgba(255, 255, 255, 0.6)',
                        'apple-text': '#1C2A3A',
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">

    <!-- Global Navigation -->
    <div class="fixed top-6 w-full z-50 px-4 md:px-6">
        <nav
            class="max-w-7xl mx-auto bg-[#1C2A3A] rounded-full h-16 px-6 flex items-center justify-between shadow-2xl relative">
            <div class="flex items-center">
                <a href="/" class="text-xl font-bold tracking-tight text-white font-heading">evently</a>
            </div>

            <div
                class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 space-x-8 text-xs font-bold tracking-widest text-white/80 uppercase font-sans">
                <a href="/" class="hover:text-white transition-colors">For You</a>
                <a href="/events" class="hover:text-white transition-colors">Events</a>
                <a href="#" class="hover:text-white transition-colors">Venues</a>
            </div>

            <div class="flex items-center gap-4">
                <a href="/dashboard"
                    class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-[#1C2A3A] hover:bg-white/90 transition-colors border border-white shadow-md">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </a>
            </div>
        </nav>
    </div>

    <!-- Main Content -->
    <main class="pt-32 pb-16 px-6">
        <div class="max-w-7xl mx-auto">

            <!-- Header -->
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
                <div>
                    <a href="/view-event?id=1"
                        class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-[#1C2A3A]/60 hover:text-[#1C2A3A] transition-colors mb-4">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7">
                            </path>
                        </svg>
                        Back to Event
                    </a>
                    <h1 class="text-4xl md:text-5xl font-heading text-[#1C2A3A] mb-2">Event Analytics</h1>
                    <p class="text-[#1C2A3A]/60 font-sans">Summer Music Festival</p>
                </div>
                <button
                    class="px-6 py-3 bg-[#1C2A3A] text-white rounded-xl font-medium shadow-lg hover:bg-[#2C3E50] transition-all flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                        </path>
                    </svg>
                    Export Report
                </button>
            </div>

            <!-- Key Metrics -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
                <!-- Total Tickets Sold -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40">
                    <div class="flex items-start justify-between mb-4">
                        <div
                            class="w-12 h-12 bg-emerald-500/10 rounded-xl flex items-center justify-center text-emerald-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z">
                                </path>
                            </svg>
                        </div>
                        <span
                            class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-1 rounded-full">+12%</span>
                    </div>
                    <p class="text-3xl font-heading text-[#1C2A3A] mb-1">245</p>
                    <p class="text-sm text-[#1C2A3A]/60 font-medium">Tickets Sold</p>
                </div>

                <!-- Total Revenue -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40">
                    <div class="flex items-start justify-between mb-4">
                        <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                                </path>
                            </svg>
                        </div>
                        <span class="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded-full">+8%</span>
                    </div>
                    <p class="text-3xl font-heading text-[#1C2A3A] mb-1">$12,250</p>
                    <p class="text-sm text-[#1C2A3A]/60 font-medium">Total Revenue</p>
                </div>

                <!-- Remaining Seats -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40">
                    <div class="flex items-start justify-between mb-4">
                        <div
                            class="w-12 h-12 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                                </path>
                            </svg>
                        </div>
                        <span class="text-xs font-bold text-orange-600 bg-orange-50 px-2 py-1 rounded-full">18%</span>
                    </div>
                    <p class="text-3xl font-heading text-[#1C2A3A] mb-1">55</p>
                    <p class="text-sm text-[#1C2A3A]/60 font-medium">Remaining Seats</p>
                </div>

                <!-- Attendance Rate -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-6 shadow-sm border border-white/40">
                    <div class="flex items-start justify-between mb-4">
                        <div
                            class="w-12 h-12 bg-purple-500/10 rounded-xl flex items-center justify-center text-purple-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z">
                                </path>
                            </svg>
                        </div>
                        <span class="text-xs font-bold text-purple-600 bg-purple-50 px-2 py-1 rounded-full">High</span>
                    </div>
                    <p class="text-3xl font-heading text-[#1C2A3A] mb-1">82%</p>
                    <p class="text-sm text-[#1C2A3A]/60 font-medium">Capacity Filled</p>
                </div>
            </div>

            <!-- Sales Data & Ticket Distribution -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <!-- Sales Over Time -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40">
                    <h2 class="text-2xl font-heading text-[#1C2A3A] mb-6">Ticket Sales Over Time</h2>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                            <span class="font-medium text-[#1C2A3A]">Week 1</span>
                            <span class="text-2xl font-heading text-[#1C2A3A]">85</span>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                            <span class="font-medium text-[#1C2A3A]">Week 2</span>
                            <span class="text-2xl font-heading text-[#1C2A3A]">95</span>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                            <span class="font-medium text-[#1C2A3A]">Week 3</span>
                            <span class="text-2xl font-heading text-[#1C2A3A]">65</span>
                        </div>
                        <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                            <span class="font-medium text-[#1C2A3A]">Week 4</span>
                            <span class="text-2xl font-heading text-[#1C2A3A]">0</span>
                        </div>
                    </div>
                </div>

                <!-- Ticket Type Distribution -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40">
                    <h2 class="text-2xl font-heading text-[#1C2A3A] mb-6">Ticket Type Distribution</h2>
                    <div class="space-y-6">
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-4 h-4 bg-emerald-500 rounded-full"></div>
                                    <span class="font-medium text-[#1C2A3A]">General Admission</span>
                                </div>
                                <span class="text-2xl font-heading text-[#1C2A3A]">150</span>
                            </div>
                            <div class="w-full bg-[#F9F7F5] rounded-full h-3">
                                <div class="bg-emerald-500 h-3 rounded-full" style="width: 61%"></div>
                            </div>
                            <p class="text-xs text-[#1C2A3A]/60 mt-1">61% of total sales</p>
                        </div>
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <div class="flex items-center gap-3">
                                    <div class="w-4 h-4 bg-blue-500 rounded-full"></div>
                                    <span class="font-medium text-[#1C2A3A]">VIP Pass</span>
                                </div>
                                <span class="text-2xl font-heading text-[#1C2A3A]">95</span>
                            </div>
                            <div class="w-full bg-[#F9F7F5] rounded-full h-3">
                                <div class="bg-blue-500 h-3 rounded-full" style="width: 39%"></div>
                            </div>
                            <p class="text-xs text-[#1C2A3A]/60 mt-1">39% of total sales</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Revenue Breakdown -->
            <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40 mb-8">
                <h2 class="text-2xl font-heading text-[#1C2A3A] mb-6">Revenue Breakdown</h2>
                <div class="space-y-4">
                    <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                        <div class="flex items-center gap-4">
                            <div class="w-3 h-3 bg-emerald-500 rounded-full"></div>
                            <span class="font-medium text-[#1C2A3A]">General Admission</span>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-heading text-[#1C2A3A]">$7,500</p>
                            <p class="text-xs text-[#1C2A3A]/60">150 tickets × $50</p>
                        </div>
                    </div>
                    <div class="flex items-center justify-between p-4 bg-[#F9F7F5] rounded-xl">
                        <div class="flex items-center gap-4">
                            <div class="w-3 h-3 bg-blue-500 rounded-full"></div>
                            <span class="font-medium text-[#1C2A3A]">VIP Pass</span>
                        </div>
                        <div class="text-right">
                            <p class="text-xl font-heading text-[#1C2A3A]">$4,750</p>
                            <p class="text-xs text-[#1C2A3A]/60">95 tickets × $150</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Attendee Demographics -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- Registration Timeline -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40">
                    <h2 class="text-2xl font-heading text-[#1C2A3A] mb-6">Registration Timeline</h2>
                    <div class="space-y-4">
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-[#1C2A3A]/60">First Week</span>
                                <span class="font-bold text-[#1C2A3A]">85 tickets</span>
                            </div>
                            <div class="w-full bg-[#F9F7F5] rounded-full h-3">
                                <div class="bg-emerald-500 h-3 rounded-full" style="width: 35%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-[#1C2A3A]/60">Second Week</span>
                                <span class="font-bold text-[#1C2A3A]">95 tickets</span>
                            </div>
                            <div class="w-full bg-[#F9F7F5] rounded-full h-3">
                                <div class="bg-blue-500 h-3 rounded-full" style="width: 39%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-[#1C2A3A]/60">Third Week</span>
                                <span class="font-bold text-[#1C2A3A]">65 tickets</span>
                            </div>
                            <div class="w-full bg-[#F9F7F5] rounded-full h-3">
                                <div class="bg-purple-500 h-3 rounded-full" style="width: 27%"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Top Cities -->
                <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 shadow-sm border border-white/40">
                    <h2 class="text-2xl font-heading text-[#1C2A3A] mb-6">Top Cities</h2>
                    <div class="space-y-4">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl font-heading text-[#1C2A3A]">1</span>
                                <span class="font-medium text-[#1C2A3A]">New York, NY</span>
                            </div>
                            <span class="text-xl font-heading text-[#1C2A3A]">142</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl font-heading text-[#1C2A3A]">2</span>
                                <span class="font-medium text-[#1C2A3A]">Brooklyn, NY</span>
                            </div>
                            <span class="text-xl font-heading text-[#1C2A3A]">58</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl font-heading text-[#1C2A3A]">3</span>
                                <span class="font-medium text-[#1C2A3A]">Jersey City, NJ</span>
                            </div>
                            <span class="text-xl font-heading text-[#1C2A3A]">28</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-3">
                                <span class="text-2xl font-heading text-[#1C2A3A]">4</span>
                                <span class="font-medium text-[#1C2A3A]">Philadelphia, PA</span>
                            </div>
                            <span class="text-xl font-heading text-[#1C2A3A]">17</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </main>
</body>

</html>