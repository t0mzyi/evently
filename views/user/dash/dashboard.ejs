<!DOCTYPE html>
<html lang="en">

<head>
  <meta name="referrer" content="no-referrer" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Profile — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css" />
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: "#1C2A3A",
              highlight: "#2C3E50",
              secondary: "#1C2A3A",
              accent: "#5C7C8A",
              dark: "#1C2A3A",
              surface: "#F9F7F5",
            },
            apple: {
              bg: "#EAE0CF",
              card: "rgba(255, 255, 255, 0.6)",
              text: "#1C2A3A",
              secondary: "#5C7C8A",
              accent: "#1C2A3A",
            },
          },
          fontFamily: {
            heading: ["Fraunces", "serif"],
            sans: ["Inter", "sans-serif"],
          },
        },
      },
    };
  </script>
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">
  <%- include('../../partials/toast') %>
  <%- include('../../partials/navbar')%>
  <%- include('../../partials/doodles')%>

  <!-- Sidebar - Dark theme matching other pages -->
  <aside class="w-20 shrink-0 hidden lg:block fixed left-0 top-0 h-screen z-40">
    <div class="bg-[#1C2A3A] h-full flex flex-col items-center py-8 border-r border-white/10">
      <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-white/20 to-white/10 flex items-center justify-center text-white font-bold mb-8">E</div>
      <nav class="space-y-4 flex-1 flex flex-col justify-center w-full px-3">
        <!-- Profile - ACTIVE/SELECTED -->
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-white/15 border border-white/20 text-white transition-all group relative" title="Profile">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Profile</span>
        </a>

        <a href="/dashboard/hostDashboard" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Dashboard">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Dashboard</span>
        </a>

        <a href="/dashboard/myBookings" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Bookings">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Bookings</span>
        </a>

        <a href="/dashboard/calendar" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Calendar">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Calendar</span>
        </a>

        <a href="/dashboard/wallet" class="w-full aspect-square flex items-center justify-center rounded-xl text-white/60 hover:bg-white/10 hover:text-white transition-all group relative" title="Wallet">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Wallet</span>
        </a>
      </nav>
      <div class="pt-6 border-t border-white/10 mt-auto w-full px-3 space-y-3">
        <a href="/dashboard" class="w-full aspect-square flex items-center justify-center rounded-xl bg-gradient-to-br from-white/20 to-white/10 text-white text-xs font-bold" title="<%= user?.name || 'User' %>"><%= user?.name?.charAt(0) || 'U' %></a>
        <a href="/logout" class="w-full aspect-square flex items-center justify-center rounded-xl text-red-400 hover:bg-red-500/10 hover:text-red-300 transition-all group relative" title="Logout">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          <span class="absolute left-full ml-4 px-3 py-1.5 bg-[#1C2A3A] text-white text-xs rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none shadow-lg border border-white/10">Logout</span>
        </a>
      </div>
    </div>
  </aside>

  <!-- Main Content Area - with left margin for sidebar -->
  <main class="pt-28 pb-16 px-6 lg:ml-20">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="w-24 h-24 bg-[#1C2A3A] rounded-full mx-auto flex items-center justify-center text-white text-3xl font-heading mb-6 shadow-lg overflow-hidden">
          <img src="<%= user.avatarUrl %>" alt="Profile" class="w-full h-full object-cover" />
        </div>
        <h1 class="text-4xl font-heading text-[#1C2A3A] mb-2">
          <%= user.firstName + " " + user.lastName %>
        </h1>
        <p class="text-[#1C2A3A]/60 font-sans">
          Member since <%= user.createdAt?.getFullYear?.() || new Date().getFullYear() %>
        </p>
      </div>

      <!-- Profile Details Card -->
      <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] p-8 md:p-12 shadow-sm border border-white/40 mb-8">
        <h2 class="text-xl font-heading text-[#1C2A3A] mb-8 border-b border-[#1C2A3A]/10 pb-4">
          Personal Information
        </h2>

        <div class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-2">FIRST NAME</label>
              <input type="text" value="<%= user.firstName %>" class="w-full bg-transparent border-b border-[#1C2A3A]/20 py-2 text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A] transition-colors" readonly />
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-2">LAST NAME</label>
              <input type="text" value="<%= user.lastName %>" class="w-full bg-transparent border-b border-[#1C2A3A]/20 py-2 text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A] transition-colors" readonly />
            </div>
            <div class="md:col-span-2">
              <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-2">Email Address</label>
              <input type="email" value="<%= user.emailAddress %>" class="w-full bg-transparent border-b border-[#1C2A3A]/20 py-2 text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A] transition-colors" readonly />
            </div>
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-2">Bio</label>
            <input type="text" value="<%= user.bio || 'No bio added' %>" class="w-full italic bg-transparent border-b border-[#1C2A3A]/20 py-2 text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A] transition-colors" readonly />
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-[#1C2A3A]/40 mb-2">Age</label>
            <input type="text" value="<%= user.age || 'No age added' %>" class="w-full italic bg-transparent border-b border-[#1C2A3A]/20 py-2 text-[#1C2A3A] focus:outline-none focus:border-[#1C2A3A] transition-colors" readonly />
          </div>
        </div>

        <div class="mt-12 flex justify-end">
          <a href="/dashboard/editProfile" class="px-6 py-3 bg-[#1C2A3A] text-white rounded-xl font-heading text-sm hover:bg-[#2C3E50] transition-colors shadow-lg">
            Edit Profile
          </a>
        </div>
      </div>

      <!-- Logout Button (moved to bottom for better UX) -->
      <div class="flex justify-center">
        <a href="/logout" class="group relative bg-[#ED8842] rounded-[1.2rem] px-6 py-3 text-white overflow-hidden hover:shadow-lg transition-all w-fit">
          <div class="relative z-10 flex items-center gap-3">
            <span class="font-heading text-sm">Log Out</span>
            <svg class="w-4 h-4 opacity-80 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
          </div>
          <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </a>
      </div>
    </div>
  </main>
</body>

</html>