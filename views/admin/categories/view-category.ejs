<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View Category — Evently Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <style>
    .category-thumb {
      font-size: 24px;
      line-height: 1;
      display: inline-block;
      width: 24px;
      height: 24px;
      text-align: center;
    }
  </style>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: '#1C2A3A',
              highlight: '#2C3E50',
              accent: '#ED8842',
              surface: '#F9F7F5'
            },
          },
          fontFamily: {
            heading: ['Fraunces', 'serif'],
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">
  <!-- Admin Navbar -->
  <%- include('../../partials/adminNavbar', {activePage : 'categories'}) %>
  <%- include('../../partials/toast') %>

  <main class="pt-32 pb-16 px-6 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-end justify-between mb-12">
      <div class="flex items-center gap-6">
        <a href="/admin/categories" class="w-12 h-12 rounded-full bg-white/60 flex items-center justify-center hover:bg-white transition-colors shadow-sm shrink-0">
          <svg class="w-5 h-5 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7">
            </path>
          </svg>
        </a>

        <div class="flex items-center gap-4">
          <div class="w-16 h-16 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-600">
            <span class="category-thumb"><%= cat.iconUrl %></span>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-4xl font-heading font-medium tracking-tight"><%= cat.name %></h1>
              <span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700 text-[10px] font-bold uppercase tracking-widest">Active</span>
            </div>
            <p class="text-[#1C2A3A]/60"><%= totalEvents %> events • <%= cat.date.date %></p>
          </div>
        </div>
      </div>

      <a href="/admin/categories/<%= cat._id %>/edit" class="px-5 py-2.5 bg-white text-[#1C2A3A] rounded-xl text-sm font-bold shadow-sm border border-[#1C2A3A]/10 hover:bg-gray-50 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
          </path>
        </svg>
        Edit Category
      </a>
    </div>

    <!-- ✅ FIXED: Stats Grid (Using pre-calculated values from controller) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-12">
      <!-- Total Events -->
      <div class="bg-white/60 backdrop-blur-xl rounded-xl p-5 border border-white/40 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-[#1C2A3A]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-[#1C2A3A]/50 uppercase tracking-wider">Total Events</span>
        </div>
        <p class="text-3xl font-heading font-bold text-[#1C2A3A]"><%= totalEvents %></p>
        <p class="text-[10px] text-[#1C2A3A]/40 mt-1">All time</p>
      </div>

      <!-- Live Events -->
      <div class="bg-green-500/10 backdrop-blur-xl rounded-xl p-5 border border-green-500/20 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-green-700/70 uppercase tracking-wider">Live Now</span>
        </div>
        <p class="text-3xl font-heading font-bold text-green-700"><%= liveEvents %></p>
        <p class="text-[10px] text-green-600/60 mt-1">Currently active</p>
      </div>

      <!-- Total Capacity -->
      <div class="bg-blue-500/10 backdrop-blur-xl rounded-xl p-5 border border-blue-500/20 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-blue-700/70 uppercase tracking-wider">Total Capacity</span>
        </div>
        <p class="text-3xl font-heading font-bold text-blue-700"><%= totalCapacity %></p>
        <p class="text-[10px] text-blue-600/60 mt-1">Across all events</p>
      </div>

      <!-- Avg. Ticket Price -->
      <div class="bg-purple-500/10 backdrop-blur-xl rounded-xl p-5 border border-purple-500/20 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-purple-700/70 uppercase tracking-wider">Avg. Ticket Price</span>
        </div>
        <p class="text-3xl font-heading font-bold text-purple-700">₹<%= avgTicketPrice %></p>
        <p class="text-[10px] text-purple-600/60 mt-1">Average per event</p>
      </div>
    </div>

    <h2 class="text-xl font-heading font-medium mb-6">Events in <%= cat.name %></h2>

    <!-- Events List -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% if (cat.events && cat.events.length > 0) { %>
      <% for(let i=0; i<cat.events.length; i++) { %>
      <a href="/admin/events/<%= cat.events[i]._id %>" class="group bg-white/60 backdrop-blur-xl rounded-[2rem] overflow-hidden border border-white/40 shadow-sm hover:shadow-md transition-all">
        <div class="relative h-48 overflow-hidden">
          <img src="<%= cat.events[i].galleryImages && cat.events[i].galleryImages.length > 0 ? cat.events[i].galleryImages[0] : '/assets/images/placeholder.jpg' %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          <div class="absolute inset-0 bg-gradient-to-t from-[#1C2A3A]/60 to-transparent"></div>

          <!-- Status Badge -->
          <div class="absolute top-4 left-4">
            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= 
                  cat.events[i].status === 'live' ? 'bg-green-500/90 text-white' : 
                  cat.events[i].status === 'approved' ? 'bg-blue-500/90 text-white' : 
                  cat.events[i].status === 'pending' ? 'bg-yellow-500/90 text-white' : 
                  'bg-red-500/90 text-white'
                %>">
              <%= cat.events[i].status %>
            </span>
          </div>

          <div class="absolute bottom-4 left-4 text-white">
            <h3 class="text-xl font-heading"><%= cat.events[i].title %></h3>
          </div>
        </div>
        <div class="p-5">
          <div class="flex justify-between items-center text-sm text-[#1C2A3A]/60">
            <span><%= new Date(cat.events[i].startDate).toLocaleDateString() %></span>
            <span class="font-bold text-[#1C2A3A]">₹<%= cat.events[i].ticketTypes && cat.events[i].ticketTypes.length > 0 ? Math.min(...cat.events[i].ticketTypes.map(t => t.price || 0)) : 0 %></span>
          </div>
        </div>
      </a>
      <% } %>
      <% } else { %>
      <div class="col-span-full text-center py-20 bg-white/40 backdrop-blur-xl rounded-[2rem] border border-white/40">
        <svg class="w-16 h-16 mx-auto text-[#1C2A3A]/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
        </svg>
        <p class="text-[#1C2A3A]/60">No events in this category yet</p>
      </div>
      <% } %>
    </div>
  </main>
</body>

</html>