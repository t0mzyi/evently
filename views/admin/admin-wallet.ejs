<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Wallet — Evently</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: '#1C2A3A',
              highlight: '#2C3E50',
              accent: '#ED8842',
              surface: '#F9F7F5'
            },
          },
          fontFamily: {
            heading: ['Fraunces', 'serif'],
            sans: ['Inter', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    .transaction-card {
      background-color: rgba(255, 255, 255, 0.6);
      backdrop-filter: blur(12px);
      border-radius: 0.75rem;
      border-width: 1px;
      border-color: rgba(255, 255, 255, 0.4);
      box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      overflow: hidden;
      transition-property: all;
      transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      transition-duration: 200ms;
    }

    .transaction-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .status-badge.pending {
      background-color: rgba(234, 179, 8, 0.1);
      color: #b45309;
      border-width: 1px;
      border-color: rgba(234, 179, 8, 0.2);
    }

    .status-badge.completed {
      background-color: rgba(34, 197, 94, 0.1);
      color: #166534;
      border-width: 1px;
      border-color: rgba(34, 197, 94, 0.2);
    }

    .status-badge.failed {
      background-color: rgba(239, 68, 68, 0.1);
      color: #b91c1c;
      border-width: 1px;
      border-color: rgba(239, 68, 68, 0.2);
    }

    .transaction-icon.income {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 9999px;
      background-color: rgba(34, 197, 94, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #16a34a;
    }

    .transaction-icon.expense {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 9999px;
      background-color: rgba(239, 68, 68, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #dc2626;
    }

    .avatar-initial {
      width: 2rem;
      height: 2rem;
      border-radius: 9999px;
      background-color: rgba(237, 136, 66, 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      color: #ED8842;
      font-size: 0.875rem;
    }

    /* Modal styles - CRITICAL: starts HIDDEN */
    .transactions-modal {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
    }

    .transactions-modal.active {
      display: flex;
    }
  </style>
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">

  <!-- Admin Navbar -->
  <%- include('../partials/adminNavbar') %>

  <main class="pt-32 pb-16 px-6 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-8">
      <div>
        <h1 class="text-4xl font-heading font-medium tracking-tight mb-2">Platform Wallet</h1>
        <p class="text-[#1C2A3A]/60">Overview of platform revenue, commissions, and payouts.</p>
      </div>
      <div class="flex gap-3">
        <button class="px-4 py-2 bg-white/60 border border-[#1C2A3A]/10 rounded-xl text-sm font-medium hover:bg-white transition-colors flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Download Report
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left Column: Financial Overview -->
      <div class="space-y-6">
        <!-- Main Balance Card -->
        <div class="bg-[#1C2A3A] text-white rounded-[2rem] p-8 shadow-xl relative overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-white/5 rounded-full blur-3xl -mr-16 -mt-16"></div>
          <div class="mb-8">
            <p class="text-white/60 text-xs font-bold uppercase tracking-widest mb-1">Total Platform Revenue</p>
            <p class="text-4xl font-heading font-medium">₹<%= wallet.balance %></p>
            <div class="flex items-center gap-2 mt-2">
              <span class="px-2 py-0.5 rounded-lg bg-emerald-500/20 text-emerald-300 text-[10px] font-bold uppercase tracking-wider">+12.5% this month</span>
            </div>
          </div>
          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-white/70">Total Earnings</span>
              <span class="font-bold">₹<%= wallet.te %></span>
            </div>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="grid grid-cols-1 gap-4">
          <div class="bg-white/60 backdrop-blur-xl rounded-2xl p-6 border border-white/40 shadow-sm text-center">
            <p class="text-3xl font-heading font-bold text-[#1C2A3A]"><%= transactions.length %></p>
            <p class="text-xs text-[#1C2A3A]/60 uppercase tracking-wider mt-1">Transactions</p>
          </div>
        </div>
      </div>

      <!-- Main Content: Transaction History -->
      <div class="lg:col-span-2">
        <div class="bg-white/60 backdrop-blur-xl rounded-[2rem] border border-white/40 shadow-sm overflow-hidden h-full">
          <div class="px-8 py-6 border-b border-[#1C2A3A]/10 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
            <h3 class="text-lg font-heading font-medium">Recent Transactions</h3>
            <div class="flex flex-wrap gap-3">
              <input type="date" class="px-3 py-1.5 bg-white/50 border border-[#1C2A3A]/10 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#ED8842]/40">
              <select class="px-3 py-1.5 bg-white/50 border border-[#1C2A3A]/10 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#ED8842]/40">
                <option>All Types</option>
                <option>Credit</option>
                <option>Debit</option>
                <option>Pending</option>
                <option>Completed</option>
                <option>Failed</option>
              </select>
            </div>
          </div>

          <!-- Recent Transactions (First 3) -->
          <div class="divide-y divide-[#1C2A3A]/10">
            <% if (!transactions || transactions.length === 0) { %>
            <div class="text-center py-12">
              <div class="w-16 h-16 rounded-full bg-[#1C2A3A]/10 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-[#1C2A3A]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <h3 class="text-xl font-heading font-medium text-[#1C2A3A]">No transactions yet</h3>
              <p class="text-[#1C2A3A]/60 mt-2">Transactions will appear here once they're processed.</p>
            </div>
            <% } else { %>
            <% const recentTransactions = transactions.slice(0, 3); %>
            <% recentTransactions.forEach(transaction => { 
              const isCredit = transaction.type === 'credit';
              const iconClass = isCredit ? 'income' : 'expense';
              const amountPrefix = isCredit ? '+' : '-';
              const amountColor = isCredit ? 'text-green-600' : 'text-red-600';
              let statusClass = 'completed';
              if (transaction.status === 'PENDING') statusClass = 'pending';
              else if (transaction.status === 'FAILED') statusClass = 'failed';
              const formattedAmount = parseFloat(transaction.amount).toFixed(2);
              const hostName = transaction.userId?.firstName && transaction.userId?.lastName 
                ? `${transaction.userId.firstName} ${transaction.userId.lastName}`
                : 'Unknown Host';
              const eventTitle = transaction.eventId?.title || 'Unknown Event';
              const formattedDate = new Date(transaction.createdAt).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              });
            %>
            <div class="transaction-card">
              <div class="p-5">
                <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                  <div class="flex items-start gap-4">
                    <div class="transaction-icon <%= iconClass %>">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2zm0 0c1.657 0 3-.895 3-2s-1.343-2-3-2-3 .895-3 2 1.343 2 3 2zm9 4c0 1.657-1.343 3-3 3s-3-.895-3-3 1.343-3 3-3 3 .895 3 3z"></path>
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-start gap-2 mb-1">
                        <h3 class="text-lg font-heading font-bold text-[#1C2A3A]">
                          <%= transaction.description || (isCredit ? 'Event Commission' : 'Host Payout') %>
                        </h3>
                        <span class="status-badge <%= statusClass %> px-2.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider">
                          <%= transaction.status %>
                        </span>
                      </div>
                      <p class="text-[#1C2A3A]/70 mb-2">From "<%= eventTitle %>" event</p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-[#1C2A3A]/70">
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <span><%= formattedDate %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                          </svg>
                          <span><%= hostName %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 000-6H6.995a3 3 0 000 6H7z"></path>
                          </svg>
                          <span><%= transaction.paymentMethod || 'Wallet' %></span>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="flex-shrink-0 w-full md:w-auto md:text-right">
                    <div class="font-heading font-bold text-xl <%= amountColor %>"><%= amountPrefix %>₹<%= formattedAmount %></div>
                    <div class="text-xs text-[#1C2A3A]/60 mt-0.5">TXN-<%= transaction._id.toString().slice(-8).toUpperCase() %> • <%= transaction.type.toUpperCase() %></div>
                  </div>
                </div>
              </div>
            </div>
            <% }); %>
            <% } %>
          </div>

          <!-- View All Button -->
          <% if (transactions && transactions.length > 3) { %>
          <div class="p-6 border-t border-[#1C2A3A]/10 text-center">
            <button onclick="openTransactionsModal()" class="px-6 py-2.5 bg-[#1C2A3A] text-white rounded-xl font-bold hover:bg-[#2C3E50] transition-colors">
              View All Transactions (<%= transactions.length %>)
            </button>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>

  <!-- All Transactions Modal (STARTS HIDDEN) -->
  <div id="transactionsModal" class="transactions-modal">
    <div class="absolute inset-0 bg-[#1C2A3A]/60 backdrop-blur-sm" onclick="closeTransactionsModal()"></div>
    <div class="relative z-10 w-full max-w-6xl max-h-[90vh] mx-auto my-8 overflow-hidden">
      <div class="bg-white/90 rounded-[2rem] border border-white/30 flex flex-col h-full">
        <!-- Modal Header -->
        <div class="flex justify-between items-center p-6 border-b border-[#1C2A3A]/10">
          <h2 class="text-2xl font-heading font-bold text-[#1C2A3A]">All Transactions</h2>
          <button onclick="closeTransactionsModal()" class="w-9 h-9 rounded-full bg-[#1C2A3A]/10 flex items-center justify-center hover:bg-[#1C2A3A]/20 transition-colors">
            <svg class="w-5 h-5 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Modal Content -->
        <div class="flex-1 overflow-y-auto p-6">
          <% if (!transactions || transactions.length === 0) { %>
          <div class="text-center py-12">
            <div class="w-16 h-16 rounded-full bg-[#1C2A3A]/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-[#1C2A3A]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-heading font-medium text-[#1C2A3A]">No transactions found</h3>
            <p class="text-[#1C2A3A]/60 mt-2">There are no transactions to display.</p>
          </div>
          <% } else { %>
          <div class="space-y-4">
            <% transactions.forEach(transaction => { 
              const isCredit = transaction.type === 'credit';
              const iconClass = isCredit ? 'income' : 'expense';
              const amountPrefix = isCredit ? '+' : '-';
              const amountColor = isCredit ? 'text-green-600' : 'text-red-600';
              let statusClass = 'completed';
              if (transaction.status === 'PENDING') statusClass = 'pending';
              else if (transaction.status === 'FAILED') statusClass = 'failed';
              const formattedAmount = parseFloat(transaction.amount).toFixed(2);
              const hostName = transaction.userId?.firstName && transaction.userId?.lastName 
                ? `${transaction.userId.firstName} ${transaction.userId.lastName}`
                : 'Unknown Host';
              const eventTitle = transaction.eventId?.title || 'Unknown Event';
              const formattedDate = new Date(transaction.createdAt).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric'
              });
            %>
            <div class="transaction-card">
              <div class="p-5">
                <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                  <div class="flex items-start gap-4">
                    <div class="transaction-icon <%= iconClass %>">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2zm0 0c1.657 0 3-.895 3-2s-1.343-2-3-2-3 .895-3 2 1.343 2 3 2zm9 4c0 1.657-1.343 3-3 3s-3-.895-3-3 1.343-3 3-3 3 .895 3 3z"></path>
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-start gap-2 mb-1">
                        <h3 class="text-lg font-heading font-bold text-[#1C2A3A]">
                          <%= transaction.description || (isCredit ? 'Event Commission' : 'Host Payout') %>
                        </h3>
                        <span class="status-badge <%= statusClass %> px-2.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider">
                          <%= transaction.status %>
                        </span>
                      </div>
                      <p class="text-[#1C2A3A]/70 mb-2">From "<%= eventTitle %>" event</p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-[#1C2A3A]/70">
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <span><%= formattedDate %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                          </svg>
                          <span><%= hostName %></span>
                        </div>
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 000-6H6.995a3 3 0 000 6H7z"></path>
                          </svg>
                          <span><%= transaction.paymentMethod || 'Wallet' %></span>
                        </div>
                        <% if (transaction.failedReason) { %>
                        <div class="flex items-center gap-1.5">
                          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                          </svg>
                          <span class="text-red-600"><%= transaction.failedReason %></span>
                        </div>
                        <% } %>
                      </div>
                    </div>
                  </div>
                  <div class="flex-shrink-0 w-full md:w-auto md:text-right">
                    <div class="font-heading font-bold text-xl <%= amountColor %>"><%= amountPrefix %>₹<%= formattedAmount %></div>
                    <div class="text-xs text-[#1C2A3A]/60 mt-0.5">TXN-<%= transaction._id.toString().slice(-8).toUpperCase() %> • <%= transaction.type.toUpperCase() %></div>
                  </div>
                </div>
              </div>
            </div>
            <% }); %>
          </div>
          <% } %>
        </div>

        <!-- ModalFooter -->
        <div class="p-6 border-t border-[#1C2A3A]/10 flex justify-end">
          <button onclick="closeTransactionsModal()" class="px-6 py-2.5 bg-[#1C2A3A] text-white rounded-xl font-bold hover:bg-[#2C3E50] transition-colors">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Critical: JavaScript at bottom -->
  <script>
    function openTransactionsModal() {
      document.getElementById('transactionsModal').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeTransactionsModal() {
      document.getElementById('transactionsModal').classList.remove('active');
      document.body.style.overflow = 'auto';
    }

    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        const modal = document.getElementById('transactionsModal');
        if (modal.classList.contains('active')) {
          closeTransactionsModal();
        }
      }
    });

    // Close modal when clicking outside content
    document.getElementById('transactionsModal').addEventListener('click', function(e) {
      if (e.target === this) {
        closeTransactionsModal();
      }
    });
  </script>
</body>

</html>