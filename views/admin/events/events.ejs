<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Event Management — Evently Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/assets/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: '#1C2A3A',
              highlight: '#2C3E50',
              accent: '#ED8842',
              surface: '#F9F7F5'
            },
            status: {
              pending: '#ED8842',
              payment: '#3B82F6',
              live: '#10B981',
              rejected: '#EF4444'
            }
          },
          fontFamily: {
            heading: ['Fraunces', 'serif'],
            sans: ['Inter', 'sans-serif']
          },
          animation: {
            'fade-in': 'fadeIn 0.3s ease-out',
            'slide-up': 'slideUp 0.4s ease-out'
          },
          keyframes: {
            fadeIn: {
              '0%': {
                opacity: '0'
              },
              '100%': {
                opacity: '1'
              }
            },
            slideUp: {
              '0%': {
                opacity: '0',
                transform: 'translateY(10px)'
              },
              '100%': {
                opacity: '1',
                transform: 'translateY(0)'
              }
            }
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    /* Status Card Styles */
    .status-card {
      backdrop-filter: blur(12px);
      transition: all 0.3s ease;
    }

    .status-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    }

    .status-card.pending {
      background: linear-gradient(135deg, rgba(237, 136, 66, 0.08) 0%, rgba(255, 255, 255, 0.6) 100%);
      border: 1px solid rgba(237, 136, 66, 0.2);
    }

    .status-card.approved {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.08) 0%, rgba(255, 255, 255, 0.6) 100%);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .status-card.live {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.08) 0%, rgba(255, 255, 255, 0.6) 100%);
      border: 1px solid rgba(59, 130, 246, 0.2);
    }

    .status-card.rejected {
      background: linear-gradient(135deg, rgba(239, 68, 68, 0.08) 0%, rgba(255, 255, 255, 0.6) 100%);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    /* Event Card Styles */
    .event-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(12px);
    }

    .event-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(28, 42, 58, 0.12);
    }

    .event-card.status-pending {
      border-left: 4px solid #ED8842;
    }

    .event-card.status-approved {
      border-left: 4px solid #10B981;
    }

    .event-card.status-live {
      border-left: 4px solid #3B82F6;
    }

    .event-card.status-rejected {
      border-left: 4px solid #EF4444;
    }

    /* Status Badge */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border-radius: 9999px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .status-badge.pending {
      background: rgba(237, 136, 66, 0.12);
      color: #D97706;
    }

    .status-badge.approved {
      background: rgba(16, 185, 129, 0.12);
      color: #047857;
    }

    .status-badge.live {
      background: rgba(59, 130, 246, 0.12);
      color: #1D4ED8;
    }

    .status-badge.rejected {
      background: rgba(239, 68, 68, 0.12);
      color: #B91C1C;
    }

    .status-badge.pending::before,
    .status-badge.approved::before,
    .status-badge.live::before,
    .status-badge.rejected::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1;
      }

      50% {
        opacity: 0.5;
      }
    }

    /* Action Buttons */
    .action-btn {
      transition: all 0.3s ease;
      font-weight: 600;
      letter-spacing: 0.025em;
    }

    .action-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .action-btn.primary {
      background: linear-gradient(135deg, #1C2A3A 0%, #2C3E50 100%);
      color: white;
    }

    .action-btn.success {
      background: linear-gradient(135deg, #10B981 0%, #059669 100%);
      color: white;
    }

    .action-btn.danger {
      background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%);
      color: white;
    }

    .action-btn.warning {
      background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
      color: white;
    }

    /* Search & Filter */
    .filter-container {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0.4) 100%);
      backdrop-filter: blur(20px);
    }

    .search-input:focus,
    .select-input:focus {
      box-shadow: 0 0 0 3px rgba(237, 136, 66, 0.15);
    }

    /* Pagination */
    .pagination-btn {
      transition: all 0.2s ease;
    }

    .pagination-btn:hover {
      background: rgba(28, 42, 58, 0.08);
      transform: translateY(-1px);
    }

    .pagination-btn.active {
      background: #1C2A3A;
      color: white;
      box-shadow: 0 4px 12px rgba(28, 42, 58, 0.3);
    }

    /* Empty State */
    .empty-state {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(255, 255, 255, 0.4) 100%);
      border: 2px dashed rgba(28, 42, 58, 0.15);
    }

    /* Modal */
    .modal-backdrop {
      backdrop-filter: blur(8px);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .event-card-content {
        flex-direction: column;
        align-items: flex-start;
      }

      .action-group {
        width: 100%;
        justify-content: flex-start;
      }
    }
  </style>
</head>

<body class="bg-[#EAE0CF] text-[#1C2A3A] min-h-screen">
  <%- include('../../partials/toast')%>
  <!-- Admin Navbar -->
  <%- include('../../partials/adminNavbar', {activePage : 'events'}) %>
  <%-include('../../partials/doodles') %>

  <!-- ✅ FIXED: Removed ml-64, added proper centering -->
  <main class="pt-32 pb-16 px-6 max-w-7xl mx-auto min-h-screen">
    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-8 animate-fade-in">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <div class="w-12 h-12 rounded-2xl bg-[#1C2A3A] flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-4xl font-heading font-medium tracking-tight text-[#1C2A3A]">Event Management</h1>
            <p class="text-[#1C2A3A]/60 font-sans mt-1">Review, approve, and manage all platform events</p>
          </div>
        </div>
      </div>
      <div class="flex gap-3">
        <a href="/admin/reports" class="px-5 py-3 bg-white/60 backdrop-blur-xl border border-[#1C2A3A]/10 rounded-xl text-sm font-bold text-[#1C2A3A] hover:bg-white transition-all flex items-center gap-2 shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          Analytics
        </a>
      </div>
    </div>

    <!-- Stats Summary - Enhanced Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8 animate-slide-up">
      <div class="status-card bg-white/60 backdrop-blur-xl rounded-2xl p-5 border border-white/40 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-[#1C2A3A]/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-[#1C2A3A]/50 uppercase tracking-wider">Total</span>
        </div>
        <p class="text-3xl font-heading font-bold text-[#1C2A3A]"><%= liveEvents + pendingEvents + approvedEvents + rejectedEvents %></p>
        <p class="text-[10px] text-[#1C2A3A]/40 mt-1">All Events</p>
      </div>

      <div class="status-card live rounded-2xl p-5 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-blue-700/70 uppercase tracking-wider">Live</span>
        </div>
        <p class="text-3xl font-heading font-bold text-blue-700"><%= liveEvents %></p>
        <p class="text-[10px] text-blue-600/60 mt-1">Active Now</p>
      </div>

      <div class="status-card pending rounded-2xl p-5 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-yellow-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-yellow-700/70 uppercase tracking-wider">Pending</span>
        </div>
        <p class="text-3xl font-heading font-bold text-yellow-700"><%= pendingEvents %></p>
        <p class="text-[10px] text-yellow-600/60 mt-1">Awaiting Review</p>
      </div>

      <div class="status-card approved rounded-2xl p-5 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-green-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-green-700/70 uppercase tracking-wider">Approved</span>
        </div>
        <p class="text-3xl font-heading font-bold text-green-700"><%= approvedEvents %></p>
        <p class="text-[10px] text-green-600/60 mt-1">Ready to Go Live</p>
      </div>

      <div class="status-card rejected rounded-2xl p-5 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 rounded-xl bg-red-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <span class="text-[10px] font-bold text-red-700/70 uppercase tracking-wider">Rejected</span>
        </div>
        <p class="text-3xl font-heading font-bold text-red-700"><%= rejectedEvents %></p>
        <p class="text-[10px] text-red-600/60 mt-1">Needs Attention</p>
      </div>
    </div>

    <!-- Search & Filters - Enhanced -->
    <div class="filter-container rounded-2xl p-5 mb-8 border border-white/40 shadow-sm animate-slide-up" style="animation-delay: 0.1s">
      <form action="/admin/events" method="GET" class="flex flex-col md:flex-row items-center gap-4">
        <input type="hidden" name="p" value="1">

        <div class="relative w-full md:flex-1">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[#1C2A3A]/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input type="search" name="n" value="<%= searchQuery %>" placeholder="Search events by title, host, or category..." class="search-input w-full pl-12 pr-4 py-3 bg-white/80 border border-[#1C2A3A]/10 rounded-xl text-sm focus:outline-none transition-all" />
        </div>

        <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
          <div class="relative min-w-[150px]">
            <select name="t" onchange="this.form.submit()" class="select-input w-full appearance-none pl-4 pr-10 py-3 bg-white/80 border border-[#1C2A3A]/10 rounded-xl text-sm font-medium focus:outline-none cursor-pointer">
              <option value="all" <%= selectedType === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="pending" <%= selectedType === 'pending' ? 'selected' : '' %>>Pending</option>
              <option value="approved" <%= selectedType === 'approved' ? 'selected' : '' %>>Approved</option>
              <option value="live" <%= selectedType === 'live' ? 'selected' : '' %>>Live</option>
              <option value="rejected" <%= selectedType === 'rejected' ? 'selected' : '' %>>Rejected</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#1C2A3A]/40 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>

          <div class="relative min-w-[160px]">
            <select name="s" onchange="this.form.submit()" class="select-input w-full appearance-none pl-4 pr-10 py-3 bg-white/80 border border-[#1C2A3A]/10 rounded-xl text-sm font-medium focus:outline-none cursor-pointer">
              <option value="name-asc" <%= selectedSort === 'name-asc' ? 'selected' : '' %>>Name A-Z</option>
              <option value="name-desc" <%= selectedSort === 'name-desc' ? 'selected' : '' %>>Name Z-A</option>
              <option value="createdAt-desc" <%= selectedSort === 'createdAt-desc' ? 'selected' : '' %>>Newest First</option>
              <option value="createdAt-asc" <%= selectedSort === 'createdAt-asc' ? 'selected' : '' %>>Oldest First</option>
            </select>
            <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[#1C2A3A]/40 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>
        </div>
      </form>
    </div>

    <!-- Events Cards Grid -->
    <div class="space-y-4 mb-8">
      <% if (events.length === 0) { %>
      <div class="empty-state rounded-3xl p-16 text-center animate-fade-in">
        <div class="mx-auto w-20 h-20 rounded-full bg-[#ED8842]/10 flex items-center justify-center mb-6">
          <svg class="w-10 h-10 text-[#ED8842]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-heading font-bold text-[#1C2A3A] mb-3">No Events Found</h3>
        <p class="text-[#1C2A3A]/60 max-w-md mx-auto mb-6">There are no events matching your current filters. Try adjusting your search criteria or status filter.</p>
        <a href="/admin/events" class="inline-flex items-center gap-2 px-6 py-3 bg-[#1C2A3A] text-white rounded-xl font-bold text-sm hover:bg-[#2C3E50] transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Reset Filters
        </a>
      </div>
      <% } else { %>
      <% for(let i = 0; i < events.length; i++) { %>
      <div class="event-card status-<%= events[i].status %> bg-white/70 backdrop-blur-xl rounded-2xl border border-white/40 shadow-sm overflow-hidden animate-slide-up" style="animation-delay: <%= i * 0.05 %>s">
        <div class="p-6">
          <div class="flex flex-col lg:flex-row lg:items-start gap-6">
            <!-- Event Info -->
            <div class="flex-1 min-w-0">
              <div class="flex items-start gap-4 mb-4">
                <!-- Status Icon -->
                <div class="flex-shrink-0">
                  <div class="w-14 h-14 rounded-2xl flex items-center justify-center <%= events[i].status === 'pending' ? 'bg-yellow-500/10 text-yellow-600' : events[i].status === 'approved' ? 'bg-green-500/10 text-green-600' : events[i].status === 'live' ? 'bg-blue-500/10 text-blue-600' : 'bg-red-500/10 text-red-600' %>">
                    <% if(events[i].status === "pending") { %>
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <% } else if(events[i].status === "approved") { %>
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <% } else if(events[i].status === "live") { %>
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <% } else { %>
                    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <% } %>
                  </div>
                </div>

                <!-- Event Details -->
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h3 class="text-xl font-heading font-bold text-[#1C2A3A] truncate"><%= events[i].title %></h3>
                    <span class="status-badge <%= events[i].status %>">
                      <% if(events[i].status === "pending") { %>
                      Pending Review
                      <% } else if(events[i].status === "approved") { %>
                      Payment Pending
                      <% } else if(events[i].status === "live") { %>
                      Live Event
                      <% } else { %>
                      Rejected
                      <% } %>
                    </span>
                  </div>

                  <div class="flex flex-wrap gap-4 text-sm text-[#1C2A3A]/60 mb-3">
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                      <span><%= events[i].formatDate %></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      <span><%= (events[i].hostId?.firstName || '') + ' ' + (events[i].hostId?.lastName || '') || 'Unknown Organizer' %></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                      </svg>
                      <span><%= events[i].categoryId?.name || 'General' %></span>
                    </div>
                  </div>

                  <!-- Ticket Info -->
                  <div class="flex items-center gap-4 pt-4 border-t border-[#1C2A3A]/5">
                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-lg bg-[#1C2A3A]/5 flex items-center justify-center">
                        <svg class="w-4 h-4 text-[#1C2A3A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                        </svg>
                      </div>
                      <div>
                        <p class="text-xs text-[#1C2A3A]/50 font-bold uppercase">Tickets</p>
                        <p class="text-sm font-bold text-[#1C2A3A]"><%= events[i].availableTickets %> / <%= events[i].totalTickets %> Left</p>
                      </div>
                    </div>

                    <div class="w-px h-10 bg-[#1C2A3A]/10"></div>

                    <div class="flex items-center gap-2">
                      <div class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center">
                        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                      </div>
                      <div>
                        <p class="text-xs text-[#1C2A3A]/50 font-bold uppercase">Price</p>
                        <p class="text-sm font-bold text-[#1C2A3A]"><%= events[i].minPrice === 0 ? 'Free' : '₹' + events[i].minPrice %></p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex-shrink-0 flex flex-col gap-2 lg:w-48">
              <% if(events[i].status === "pending") { %>
              <a href="/admin/events/<%= events[i]._id%>" class="action-btn primary px-5 py-3 rounded-xl text-sm flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                Review Event
              </a>
              <% } else if(events[i].status === "approved" || events[i].status === "live") { %>
              <a href="/admin/events/<%= events[i]._id%>" class="action-btn success px-5 py-3 rounded-xl text-sm flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Manage Event
              </a>
              <% } else if(events[i].status === "rejected") { %>
              <a href="/admin/events/<%= events[i]._id%>" class="action-btn warning px-5 py-3 rounded-xl text-sm flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                </svg>
                View Details
              </a>
              <% } %>
            </div>
          </div>
        </div>
      </div>
      <% } %>
      <% } %>
    </div>

    <!-- Pagination - Enhanced -->
    <% if (totalEvents > 0 && totalPages > 1) { %>
    <div class="filter-container rounded-2xl px-6 py-5 border border-white/40 shadow-sm animate-fade-in">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-[#1C2A3A]/60">
          Showing <strong class="text-[#1C2A3A]"><%= events.length %></strong> of <strong class="text-[#1C2A3A]"><%= totalEvents %></strong> events
        </p>

        <div class="flex items-center gap-2">
          <% if (currentPage > 1) { %>
          <a href="/admin/events?p=<%= currentPage - 1 %><%= (searchQuery ? '&n=' + encodeURIComponent(searchQuery) : '') %><%= (selectedType && selectedType !== 'all' ? '&t=' + encodeURIComponent(selectedType) : '') %><%= (selectedSort && selectedSort !== 'name-asc' ? '&s=' + encodeURIComponent(selectedSort) : '') %>" class="pagination-btn w-10 h-10 rounded-xl flex items-center justify-center text-[#1C2A3A]/60 hover:text-[#1C2A3A]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
          </a>
          <% } %>

          <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
          <% if (i === currentPage) { %>
          <span class="pagination-btn active w-10 h-10 rounded-xl flex items-center justify-center text-sm font-bold"><%= i %></span>
          <% } else { %>
          <a href="/admin/events?p=<%= i %><%= (searchQuery ? '&n=' + encodeURIComponent(searchQuery) : '') %><%= (selectedType && selectedType !== 'all' ? '&t=' + encodeURIComponent(selectedType) : '') %><%= (selectedSort && selectedSort !== 'name-asc' ? '&s=' + encodeURIComponent(selectedSort) : '') %>" class="pagination-btn w-10 h-10 rounded-xl flex items-center justify-center text-sm font-medium text-[#1C2A3A]"><%= i %></a>
          <% } %>
          <% } %>

          <% if (currentPage < totalPages) { %>
          <a href="/admin/events?p=<%= currentPage + 1 %><%= (searchQuery ? '&n=' + encodeURIComponent(searchQuery) : '') %><%= (selectedType && selectedType !== 'all' ? '&t=' + encodeURIComponent(selectedType) : '') %><%= (selectedSort && selectedSort !== 'name-asc' ? '&s=' + encodeURIComponent(selectedSort) : '') %>" class="pagination-btn w-10 h-10 rounded-xl flex items-center justify-center text-[#1C2A3A]/60 hover:text-[#1C2A3A]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </main>

  <!-- Reject Reason Modal - Enhanced -->
  <div id="rejectModal" class="fixed inset-0 z-[100] hidden">
    <div class="modal-backdrop absolute inset-0 bg-[#1C2A3A]/60" onclick="closeRejectModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md p-4">
      <div class="bg-white rounded-[2rem] shadow-2xl overflow-hidden animate-slide-up">
        <div class="px-8 py-6 border-b border-[#1C2A3A]/10 bg-gradient-to-r from-red-50 to-white">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-red-500/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-heading font-bold text-[#1C2A3A]">Reject Event</h3>
              <p class="text-sm text-[#1C2A3A]/60">Please provide a reason for rejection</p>
            </div>
          </div>
        </div>
        <div class="p-8 space-y-6">
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest text-[#1C2A3A]/60 mb-3">Rejection Reason</label>
            <textarea id="rejectReason" rows="4" class="w-full px-4 py-3 bg-[#F9F7F5] border border-[#1C2A3A]/10 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-500/20 focus:border-red-500/30 resize-none transition-all" placeholder="e.g. Inappropriate content, incomplete information, policy violation..."></textarea>
          </div>
          <div class="flex gap-3">
            <button onclick="closeRejectModal()" class="flex-1 py-3.5 bg-[#F9F7F5] border border-[#1C2A3A]/10 text-[#1C2A3A] rounded-xl font-bold hover:bg-[#1C2A3A]/5 transition-all">Cancel</button>
            <button onclick="confirmRejection()" class="flex-1 py-3.5 bg-red-500 text-white rounded-xl font-bold hover:bg-red-600 shadow-lg shadow-red-500/25 transition-all hover:scale-[1.02]">Confirm Rejection</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Animation on scroll
    document.addEventListener('DOMContentLoaded', function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.style.opacity = '1';
            entry.target.style.transform = 'translateY(0)';
          }
        });
      }, {
        threshold: 0.1
      });

      document.querySelectorAll('.event-card').forEach(card => {
        observer.observe(card);
      });
    });
  </script>
</body>

</html>